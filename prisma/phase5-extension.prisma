}

// --- Route Optimisation ---

enum RoutePlanStatus {
  draft
  generated
  review_required
  selected
  rejected
  expired
}

enum RouteConstraintType {
  wheelchair_accessible_vehicle_required
  extra_boarding_time
  assistance_animal
  max_time_in_vehicle
  appointment_deadline
  return_trip_required
  driver_assistance_required
  participant_preference
}

model RoutePlan {
  id                 String          @id @default(cuid())
  transportBookingId String?
  status             RoutePlanStatus @default(draft)
  createdById        String?
  createdAt          DateTime        @default(now())

  stops       RouteStop[]
  constraints RouteConstraint[]
  candidates  RoutePlanCandidate[]
  decisions   RoutePlanDecision[]
}

model RouteStop {
  id          String @id @default(cuid())
  routePlanId String
  routePlan   RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  sequence    Int
  label       String
  address     String?
}

model RouteConstraint {
  id          String              @id @default(cuid())
  routePlanId String
  routePlan   RoutePlan           @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  type        RouteConstraintType
  description String
}

model RoutePlanCandidate {
  id          String @id @default(cuid())
  routePlanId String
  routePlan   RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  summary     String
  riskNotes   String?
  score       Float  @default(0)
}

model RoutePlanDecision {
  id          String @id @default(cuid())
  routePlanId String
  routePlan   RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  decidedById String
  outcome     String
  createdAt   DateTime @default(now())
}

model TravelTimeEstimate {
  id          String @id @default(cuid())
  routePlanId String?
  minutes     Int
  source      String @default("placeholder")
  createdAt   DateTime @default(now())
}

// --- Accessibility Map ---

enum AccessibilityFeatureType {
  step_free_entry
  accessible_parking
  accessible_toilet
  wide_doorways
  lift_access
  hearing_loop
  quiet_space
  assistance_animal_friendly
  wheelchair_seating
  accessible_public_transport_nearby
}

enum AccessibilityConfidence {
  unknown
  self_reported
  community_reviewed
  admin_verified
  assessor_verified
}

model AccessiblePlace {
  id          String   @id @default(cuid())
  name        String
  address     String?
  confidence  AccessibilityConfidence @default(unknown)
  createdAt   DateTime @default(now())

  features AccessibilityFeature[]
  reviews  AccessibilityReview[]
  links    PlaceLink[]
}

model AccessibilityFeature {
  id       String                   @id @default(cuid())
  placeId  String
  place    AccessiblePlace          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type     AccessibilityFeatureType
  notes    String?
}

model AccessibilityReview {
  id        String   @id @default(cuid())
  placeId   String
  place     AccessiblePlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String
  moderated Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AccessibilityAssessment {
  id        String   @id @default(cuid())
  placeId   String
  assessorId String?
  summary   String
  createdAt DateTime @default(now())
}

model AccessibilityDataSource {
  id    String @id @default(cuid())
  name  String
  type  String
}

model PlaceLink {
  id         String @id @default(cuid())
  placeId    String
  place      AccessiblePlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String

  @@index([entityType, entityId])
}

