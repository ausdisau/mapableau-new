// MapAble Core Phase 5 — append to schema.prisma

// --- AI Matching & Fairness ---

enum AiMatchRunStatus {
  draft
  generated
  fairness_review_required
  reviewed
  accepted
  rejected
  expired
}

enum FairnessCheckStatus {
  passed
  warning
  failed
  review_required
}

model AiMatchRun {
  id                  String           @id @default(cuid())
  matchRunId          String?
  careRequestId       String?
  transportBookingId  String?
  status              AiMatchRunStatus @default(draft)
  modelVersionId      String?
  modelVersion        MatchingModelVersion? @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)
  requestedById       String
  ruleBasedRunId      String?
  createdAt           DateTime         @default(now())
  completedAt         DateTime?

  candidates   AiMatchCandidate[]
  fairnessChecks FairnessCheck[]

  @@index([careRequestId])
  @@index([transportBookingId])
  @@index([status])
}

model AiMatchCandidate {
  id              String   @id @default(cuid())
  aiMatchRunId    String
  aiMatchRun      AiMatchRun @relation(fields: [aiMatchRunId], references: [id], onDelete: Cascade)
  matchCandidateId String?
  rank            Int      @default(0)
  aiScore         Float
  combinedScore   Float
  lowConfidence   Boolean  @default(false)
  status          String   @default("generated")
  createdAt       DateTime @default(now())

  explanations AiMatchExplanation[]
}

model AiMatchExplanation {
  id                 String @id @default(cuid())
  aiMatchCandidateId String
  aiMatchCandidate   AiMatchCandidate @relation(fields: [aiMatchCandidateId], references: [id], onDelete: Cascade)
  audience           String @default("admin")
  plainLanguage      String
  technicalDetail    String?
  createdAt          DateTime @default(now())
}

model FairnessCheck {
  id           String              @id @default(cuid())
  aiMatchRunId String
  aiMatchRun   AiMatchRun          @relation(fields: [aiMatchRunId], references: [id], onDelete: Cascade)
  status       FairnessCheckStatus @default(review_required)
  summary      String
  flagsJson    Json                @default("[]")
  createdAt    DateTime            @default(now())

  metrics FairnessMetric[]
  reviews FairnessReview[]
}

model FairnessMetric {
  id              String @id @default(cuid())
  fairnessCheckId String
  fairnessCheck   FairnessCheck @relation(fields: [fairnessCheckId], references: [id], onDelete: Cascade)
  metricKey       String
  value           Float?
  threshold       Float?
  passed          Boolean @default(true)
  explanation     String
}

model FairnessReview {
  id              String   @id @default(cuid())
  fairnessCheckId String
  fairnessCheck   FairnessCheck @relation(fields: [fairnessCheckId], references: [id], onDelete: Cascade)
  reviewerId      String
  decision        String
  notes           String?
  createdAt       DateTime @default(now())
}

model MatchingModelVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  provider    String   @default("disabled")
  active      Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())

  runs AiMatchRun[]
}

// --- Provider Verification ---

enum VerificationCheckType {
  abn
  insurance
  ndis_registration_claim
  worker_screening_policy
  incident_policy
  complaints_policy
  privacy_policy
  service_agreement_template
  vehicle_registration
  driver_licence
  accessibility_training
  manual_reference_check
}

enum VerificationCaseStatus {
  draft
  submitted
  under_review
  more_information_required
  approved
  approved_with_conditions
  rejected
  suspended
  expired
}

model ProviderVerificationCase {
  id               String                 @id @default(cuid())
  organisationId   String
  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  status           VerificationCaseStatus @default(draft)
  submittedAt      DateTime?
  decidedAt        DateTime?
  createdById      String?
  adminOwnerId     String?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  checks     ProviderVerificationCheck[]
  documents  ProviderVerificationDocument[]
  decisions  ProviderVerificationDecision[]
  riskRating ProviderRiskRating?
  renewals   VerificationRenewal[]

  @@index([organisationId, status])
}

model ProviderVerificationCheck {
  id        String                @id @default(cuid())
  caseId    String
  case      ProviderVerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  checkType VerificationCheckType
  status    String                @default("pending")
  expiresAt DateTime?
  notes     String?
}

model ProviderVerificationDocument {
  id         String @id @default(cuid())
  caseId     String
  case       ProviderVerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  documentId String?
  label      String
}

model ProviderVerificationDecision {
  id          String   @id @default(cuid())
  caseId      String
  case        ProviderVerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decidedById String
  outcome     VerificationCaseStatus
  conditions  String?
  reason      String?
  createdAt   DateTime @default(now())
}

model ProviderRiskRating {
  id             String @id @default(cuid())
  caseId         String @unique
  case           ProviderVerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  organisationId String
  score          Float
  factorsJson    Json   @default("[]")
  updatedAt      DateTime @updatedAt
}

model VerificationRenewal {
  id             String   @id @default(cuid())
  caseId         String
  case           ProviderVerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  organisationId String
  dueAt          DateTime
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

// --- NDIS Pricing ---

enum NdisPriceImportStatus {
  uploaded
  parsed
  validated
  review_required
  approved
  applied
  failed
  cancelled
}

enum NdisPriceChangeType {
  new_item
  updated_price
  retired_item
  changed_unit
  changed_category
  changed_conditions
}

model NdisPriceCatalogue {
  id          String   @id @default(cuid())
  name        String
  sourceLabel String?
  active      Boolean  @default(false)
  createdAt   DateTime @default(now())

  versions NdisPriceCatalogueVersion[]
}

model NdisPriceCatalogueVersion {
  id          String   @id @default(cuid())
  catalogueId String
  catalogue   NdisPriceCatalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
  version     String
  appliedAt   DateTime?
  createdAt   DateTime @default(now())

  importJobs NdisPriceImportJob[]
  prices     NdisSupportItemPrice[]
}

model NdisPriceImportJob {
  id          String              @id @default(cuid())
  versionId   String?
  version     NdisPriceCatalogueVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  status      NdisPriceImportStatus @default(uploaded)
  fileName    String?
  rowCount    Int                 @default(0)
  createdById String
  createdAt   DateTime            @default(now())

  rows NdisPriceImportRow[]
}

model NdisPriceImportRow {
  id        String @id @default(cuid())
  jobId     String
  job       NdisPriceImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowNumber Int
  rawJson   Json
  valid     Boolean @default(true)
  errors    String?
}

model NdisPriceChange {
  id         String              @id @default(cuid())
  changeType NdisPriceChangeType
  supportItemCode String
  message    String
  appliedAt  DateTime?
  createdAt  DateTime            @default(now())
}

model NdisSupportItemPrice {
  id            String   @id @default(cuid())
  versionId     String
  version       NdisPriceCatalogueVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  supportItemId String
  supportItem   NdisSupportItem @relation(fields: [supportItemId], references: [id], onDelete: Cascade)
  priceCapCents Int
  unitType      String
  effectiveFrom DateTime
  effectiveTo   DateTime?
}

model NdisPriceRule {
  id          String @id @default(cuid())
  code        String @unique
  description String
  ruleJson    Json
  active      Boolean @default(true)
}

