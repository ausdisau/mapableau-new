  owner       String?
}

model VendorRiskAssessment {
  id       String @id @default(cuid())
  vendor   String
  riskLevel String
  notes    String?
  reviewedAt DateTime?
}

model AccessReview {
  id          String @id @default(cuid())
  scope       String
  reviewerId  String
  status      String @default("open")
  completedAt DateTime?
}

model ChangeManagementRecord {
  id          String @id @default(cuid())
  title       String
  changeType  String
  approvedById String?
  createdAt   DateTime @default(now())
}

model IncidentResponseExercise {
  id        String @id @default(cuid())
  title     String
  conductedAt DateTime?
  outcome   String?
}

// --- NDIA Readiness ---

enum NdiaIntegrationMode {
  not_configured
  manual_export
  plan_manager_export
  dry_run
  approved_api_placeholder
}

model NdiaIntegrationProfile {
  id     String              @id @default(cuid())
  mode   NdiaIntegrationMode @default(not_configured)
  notes  String?
}

model NdiaApiReadinessChecklist {
  id        String @id @default(cuid())
  itemKey   String
  completed Boolean @default(false)
  notes     String?
}

model NdiaClaimEvidenceBundle {
  id            String @id @default(cuid())
  invoiceId     String
  referencesJson Json  @default("{}")
  status        String @default("draft")
  createdAt     DateTime @default(now())

  dryRuns NdiaSubmissionDryRun[]
  audits  NdiaIntegrationAudit[]
}

model NdiaAdapterConfig {
  id       String @id @default(cuid())
  adapter  String @unique
  configJson Json @default("{}")
  active   Boolean @default(false)
}

model NdiaSubmissionDryRun {
  id        String @id @default(cuid())
  bundleId  String
  bundle    NdiaClaimEvidenceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  result    String
  findingsJson Json?
  createdAt DateTime @default(now())
}

model NdiaIntegrationAudit {
  id        String @id @default(cuid())
  bundleId  String?
  bundle    NdiaClaimEvidenceBundle? @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  action    String
  actorId   String?
  createdAt DateTime @default(now())
}
