// --- Developer API ---

enum DeveloperAppStatus {
  draft
  pending_review
  approved
  suspended
  revoked
}

enum ApiScope {
  places_read
  providers_read
  bookings_read
  bookings_write
  invoices_read
  support_tickets_write
  webhooks_receive
}

model DeveloperOrganisation {
  id        String @id @default(cuid())
  name      String
  contactEmail String?
  createdAt DateTime @default(now())

  apps DeveloperApp[]
}

model DeveloperApp {
  id                    String             @id @default(cuid())
  developerOrganisationId String
  developerOrganisation DeveloperOrganisation @relation(fields: [developerOrganisationId], references: [id], onDelete: Cascade)
  name                  String
  status                DeveloperAppStatus @default(draft)
  createdAt             DateTime           @default(now())

  apiKeys   DeveloperApiKey[]
  webhooks  DeveloperWebhookEndpoint[]
  usageLogs ApiUsageLog[]
