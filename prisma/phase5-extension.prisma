model DeveloperApiKey {
  id        String   @id @default(cuid())
  appId     String
  app       DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  keyHash   String
  keyPrefix String
  scopes    ApiScope[]
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model DeveloperWebhookEndpoint {
  id        String @id @default(cuid())
  appId     String
  app       DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  url       String
  secretHash String?
  active    Boolean @default(true)
}

model DeveloperWebhookDelivery {
  id         String @id @default(cuid())
  endpointId String
  eventType  String
  status     String
  createdAt  DateTime @default(now())
}

model ApiAccessScope {
  id    String @id @default(cuid())
  scope ApiScope @unique
  label String
}

model ApiUsageLog {
  id        String @id @default(cuid())
  appId     String
  app       DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  path      String
  method    String
  status    Int
  createdAt DateTime @default(now())
}

model ApiRateLimitRule {
  id           String @id @default(cuid())
  scope        ApiScope?
  requestsPerMinute Int @default(60)
  active       Boolean @default(true)
}

