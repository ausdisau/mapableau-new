// MapAble Access — append to schema.prisma

enum AccessPlaceCategory {
  cafe_restaurant
  bar_pub
  shop
  shopping_centre
  park
  beach
  library
  museum_gallery
  theatre_cinema
  sports_venue
  community_centre
  health_service
  education
  transport_station
  public_toilet
  accommodation
  tourism_attraction
  government_service
  other
}

enum AccessPlaceStatus {
  draft
  pending_moderation
  published
  hidden
  archived
}

enum AccessPlaceSourceType {
  user_suggested
  imported
  venue_claimed
  mapable_verified
  manual_admin
}

enum AccessPlaceFeatureType {
  step_free_entry
  accessible_parking
  accessible_toilet
  changing_places
  lift_access
  ramp_access
  wide_doorways
  wide_paths
  hearing_loop
  braille_tactile_signage
  quiet_space
  low_sensory_environment
  assistance_animals_welcome
  accessible_dropoff
  public_transport_nearby
}

enum AccessConfidenceLevel {
  unknown
  user_reported
  multiple_user_reports
  venue_claimed
  mapable_verified
  mapable_accredited
}

enum AccessReviewStatus {
  draft
  pending
  published
  hidden
  rejected
}

enum AccessReviewVisibility {
  public
  mapable_only
}

enum AccessDisplayNameMode {
  named
  first_name
  anonymous_public
}

enum AccessRatingValue {
  not_applicable
  unknown
  poor
  basic
  good
  excellent
}

enum AccessRatingCategory {
  accessible_parking
  public_transport_dropoff
  path_to_entrance
  main_entrance
  doorway
  internal_movement
  ramps_lifts
  service_counter
  seating_furniture
  accessible_toilet
  ambulant_toilet
  signage
  hearing_access
  lighting_acoustics
  online_information
  staff_training
  service_access
}

enum AccessImportSourceType {
  uploaded_kml
  kml_network_link
  google_my_maps_kml
  geojson_upload
  csv
  manual_admin_entry
}

enum AccessImportJobStatus {
  pending
  parsing
  preview_ready
  committing
  completed
  failed
  cancelled
}

enum AccessImportItemStatus {
  pending
  accepted
  skipped
  conflict
}

enum AccessAccreditationLevel {
  fail
  bronze
  silver
  gold
  not_applicable
}

enum AccessAccreditationAssessmentStatus {
  draft
  assessor_review
  evidence_required
  scored
  published
  expired
  withdrawn
}

enum AccessAccreditationTier {
  not_accredited
  bronze
  silver
  gold
}

enum AccessVenueClaimStatus {
  submitted
  needs_evidence
  approved
  rejected
  revoked
}

enum AccessModerationStatus {
  pending
  approved
  rejected
  hidden
  needs_changes
  escalated
}

enum AccessContentReportReason {
  inaccurate_access_information
  abusive_or_harassing
  private_information
  defamatory_or_unverified_claim
  unsafe_advice
  spam
  duplicate_place
  closed_or_moved_place
  other
}

model AccessPlace {
  id               String              @id @default(cuid())
  name             String
  category         AccessPlaceCategory @default(other)
  description      String?
  addressText      String?             @map("address_text")
  suburb           String?
  stateOrRegion    String?             @map("state_or_region")
  country          String              @default("AU")
  status           AccessPlaceStatus   @default(draft)
  sourceType       AccessPlaceSourceType @default(user_suggested) @map("source_type")
  sourceReference  String?             @map("source_reference")
  confidence       AccessConfidenceLevel @default(unknown)
  createdById      String?             @map("created_by")
  createdBy        User?               @relation("AccessPlaceCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  location         AccessPlaceLocation?
  features         AccessPlaceFeature[]
  sources          AccessPlaceSource[]
  claims           AccessPlaceClaim[]
  reports          AccessPlaceReport[]
  events           AccessPlaceEvent[]
  reviews          AccessPlaceReview[]
  ratingSummaries  AccessRatingSummary[]
  accreditationAssessments AccessAccreditationAssessment[]
  venueClaims      AccessVenueClaim[]
  venueProfile     AccessVenueProfile?
  importItems      AccessImportItem[]

  @@index([status])
  @@index([suburb, stateOrRegion])
  @@map("access_places")
}

model AccessPlaceLocation {
  id        String   @id @default(cuid())
  placeId   String   @unique @map("place_id")
  place     AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  geohash   String?
  @@map("access_place_locations")
}

model AccessPlaceFeature {
  id      String               @id @default(cuid())
  placeId String               @map("place_id")
  place   AccessPlace          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type    AccessPlaceFeatureType
  notes   String?
  @@unique([placeId, type])
  @@map("access_place_features")
}

model AccessPlaceSource {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  place     AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  sourceType AccessImportSourceType @map("source_type")
  sourceUrl  String?  @map("source_url")
  externalId String? @map("external_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_place_sources")
}

model AccessPlaceClaim {
  id          String   @id @default(cuid())
  placeId     String   @map("place_id")
  place       AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation("AccessPlaceClaimUser", fields: [userId], references: [id])
  status      AccessVenueClaimStatus @default(submitted)
  evidenceNote String? @map("evidence_note")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("access_place_claims")
}

model AccessPlaceReport {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  place     AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reporterId String? @map("reporter_id")
  reporter  User?    @relation("AccessPlaceReportReporter", fields: [reporterId], references: [id])
  reason    AccessContentReportReason
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_place_reports")
}

model AccessPlaceEvent {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  place     AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  actorId   String?  @map("actor_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_place_events")
}

model AccessPlaceReview {
  id                 String   @id @default(cuid())
  placeId            String   @map("place_id")
  place              AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reviewerProfileId  String   @map("reviewer_profile_id")
  reviewer           User     @relation("AccessPlaceReviewAuthor", fields: [reviewerProfileId], references: [id])
  displayNameMode    AccessDisplayNameMode @default(anonymous_public) @map("display_name_mode")
  visitDate          DateTime? @map("visit_date")
  reviewBody         String   @map("review_body")
  mobilityContext    String?  @map("mobility_context")
  status             AccessReviewStatus @default(draft)
  visibility         AccessReviewVisibility @default(public)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  ratings            AccessPlaceReviewRating[]
  photos             AccessPlaceReviewPhoto[]
  reports            AccessPlaceReviewReport[]
  events             AccessPlaceReviewEvent[]
  venueResponses     AccessVenueReviewResponse[]
  moderationItems    AccessModerationQueue[]

  @@index([placeId, status])
  @@map("access_reviews")
}

model AccessPlaceReviewRating {
  id       String              @id @default(cuid())
  reviewId String              @map("review_id")
  review   AccessPlaceReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  category AccessRatingCategory
  value    AccessRatingValue
  @@unique([reviewId, category])
  @@map("access_review_ratings")
}

model AccessPlaceReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  review    AccessPlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  storagePath String @map("storage_path")
  altText   String?  @map("alt_text")
  mimeType  String?  @map("mime_type")
  status    AccessModerationStatus @default(pending)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_review_photos")
}

model AccessPlaceReviewReport {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  review    AccessPlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporterId String? @map("reporter_id")
  reason    AccessContentReportReason
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_review_reports")
}

model AccessPlaceReviewEvent {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  review    AccessPlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  actorId   String?  @map("actor_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_review_events")
}

model AccessRatingSummary {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  place     AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category  AccessRatingCategory
  avgScore  Float?   @map("avg_score")
  sampleCount Int    @default(0) @map("sample_count")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([placeId, category])
  @@map("access_rating_summaries")
}

model AccessImportJob {
  id          String   @id @default(cuid())
  status      AccessImportJobStatus @default(pending)
  sourceType  AccessImportSourceType @map("source_type")
  sourceUrl   String?  @map("source_url")
  fileName    String?  @map("file_name")
  createdById String   @map("created_by")
  createdBy   User     @relation("AccessImportCreatedBy", fields: [createdById], references: [id])
  errorMessage String? @map("error_message")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sources     AccessImportSource[]
  items       AccessImportItem[]
  conflicts   AccessImportConflict[]

  @@map("access_import_jobs")
}

model AccessImportSource {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  job       AccessImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String?
  rawMeta   Json?    @map("raw_meta")
  @@map("access_import_sources")
}

model AccessImportItem {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  job         AccessImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status      AccessImportItemStatus @default(pending)
  name        String
  description String?
  latitude    Float?
  longitude   Float?
  category    String?
  externalRef String?  @map("external_ref")
  matchedPlaceId String? @map("matched_place_id")
  matchedPlace AccessPlace? @relation(fields: [matchedPlaceId], references: [id])
  rawData     Json?    @map("raw_data")
  @@map("access_import_items")
}

model AccessImportConflict {
  id            String   @id @default(cuid())
  jobId         String   @map("job_id")
  job           AccessImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importItemId  String   @map("import_item_id")
  existingPlaceId String? @map("existing_place_id")
  resolution    String?
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("access_import_conflicts")
}

model AccessAccreditationCriterion {
  id          String   @id @default(cuid())
  code        String   @unique
  domain      String
  title       String
  weight      Int
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  @@map("access_accreditation_criteria")
}

model AccessAccreditationAssessment {
  id          String   @id @default(cuid())
  placeId     String   @map("place_id")
  place       AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  assessorId  String   @map("assessor_id")
  assessor    User     @relation("AccessAccreditationAssessor", fields: [assessorId], references: [id])
  status      AccessAccreditationAssessmentStatus @default(draft)
  totalScore  Float?   @map("total_score")
  tier        AccessAccreditationTier?
  publishedAt DateTime? @map("published_at")
  expiresAt   DateTime? @map("expires_at")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  scores      AccessAccreditationScore[]
  evidence    AccessAccreditationEvidence[]
  events      AccessAccreditationEvent[]

  @@index([placeId, status])
  @@map("access_accreditation_assessments")
}

model AccessAccreditationScore {
  id            String   @id @default(cuid())
  assessmentId  String   @map("assessment_id")
  assessment    AccessAccreditationAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criterionCode String   @map("criterion_code")
  level         AccessAccreditationLevel
  weightedScore Float?   @map("weighted_score")
  notes         String?
  @@unique([assessmentId, criterionCode])
  @@map("access_accreditation_scores")
}

model AccessAccreditationEvidence {
  id            String   @id @default(cuid())
  assessmentId  String   @map("assessment_id")
  assessment    AccessAccreditationAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  storagePath   String   @map("storage_path")
  caption       String?
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("access_accreditation_evidence")
}

model AccessAccreditationEvent {
  id            String   @id @default(cuid())
  assessmentId  String   @map("assessment_id")
  assessment    AccessAccreditationAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  actorId       String?  @map("actor_id")
  action        String
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("access_accreditation_events")
}

model AccessVenueClaim {
  id          String   @id @default(cuid())
  placeId     String   @map("place_id")
  place       AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation("AccessVenueClaimUser", fields: [userId], references: [id])
  status      AccessVenueClaimStatus @default(submitted)
  businessName String? @map("business_name")
  evidenceNote String? @map("evidence_note")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("access_venue_claims")
}

model AccessVenueProfile {
  id          String   @id @default(cuid())
  placeId     String   @unique @map("place_id")
  place       AccessPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
  ownerUserId String   @map("owner_user_id")
  owner       User     @relation("AccessVenueOwner", fields: [ownerUserId], references: [id])
  accessInfo  String?  @map("access_info")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("access_venue_profiles")
}

model AccessVenueReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  review    AccessPlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  venueUserId String @map("venue_user_id")
  venueUser User     @relation("AccessVenueResponseAuthor", fields: [venueUserId], references: [id])
  body      String
  status    AccessModerationStatus @default(pending)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_venue_review_responses")
}

model AccessAccreditationRequest {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  userId    String   @map("user_id")
  user      User     @relation("AccessAccreditationRequestUser", fields: [userId], references: [id])
  status    String   @default("submitted")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_accreditation_requests")
}

model AccessVenueEvidence {
  id        String   @id @default(cuid())
  claimId   String?  @map("claim_id")
  placeId   String   @map("place_id")
  userId    String   @map("user_id")
  storagePath String @map("storage_path")
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_venue_evidence")
}

model AccessModerationQueue {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  reviewId    String?  @map("review_id")
  review      AccessPlaceReview? @relation(fields: [reviewId], references: [id])
  status      AccessModerationStatus @default(pending)
  priority    Int      @default(0)
  flagReason  String?  @map("flag_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  decisions   AccessModerationDecision[]

  @@index([status, createdAt])
  @@map("access_moderation_queue")
}

model AccessModerationDecision {
  id          String   @id @default(cuid())
  queueId     String   @map("queue_id")
  queue       AccessModerationQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  moderatorId String   @map("moderator_id")
  moderator   User     @relation("AccessModerator", fields: [moderatorId], references: [id])
  status      AccessModerationStatus
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("access_moderation_decisions")
}

model AccessContentReport {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  reporterId  String?  @map("reporter_id")
  reporter    User?    @relation("AccessContentReporter", fields: [reporterId], references: [id])
  reason      AccessContentReportReason
  details     String?
  status      AccessModerationStatus @default(pending)
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("access_content_reports")
}

model AccessTrustEvent {
  id        String   @id @default(cuid())
  entityType String  @map("entity_type")
  entityId  String   @map("entity_id")
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("access_trust_events")
}
