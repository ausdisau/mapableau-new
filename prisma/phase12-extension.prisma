// MapAble Core Phase 12 — Federated institutional accountability
// Implements deferred Phase 11 preview themes plus institutional permanence.

model NationalAccountabilityPublication {
  id          String   @id @default(cuid())
  periodLabel String
  title       String
  summary     String
  category    String
  status      String   @default("draft")
  metricsJson Json?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

model ConstitutionalSafeguard {
  id        String   @id @default(cuid())
  articleKey String  @unique
  title     String
  body      String
  status    String   @default("active")
  sortOrder Int      @default(0)
  ratifiedAt DateTime?
  createdAt DateTime @default(now())
}

model CommunityGovernanceMembership {
  id           String   @id @default(cuid())
  memberLabel  String
  membershipType String @default("community")
  region       String?
  status       String   @default("active")
  joinedAt     DateTime @default(now())
  disclaimer   String   @default("Directory entry only — no personal contact details published.")
}

model TransportInvestmentModelRun {
  id          String   @id @default(cuid())
  scenarioKey String
  title       String
  regionCode  String?
  status      String   @default("draft")
  inputsJson  Json?
  outputsJson Json?
  suppressed  Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

model CertifiedApiEcosystemEntry {
  id             String   @id @default(cuid())
  organisationId String
  appName        String
  certificationTier String @default("standard")
  status         String   @default("listed")
  listedAt       DateTime @default(now())
  expiresAt      DateTime?
}

model ResearchFederationNode {
  id          String   @id @default(cuid())
  nodeName    String
  institution String?
  status      String   @default("pending")
  syntheticOnly Boolean @default(true)
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model InstitutionalContinuityPlan {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("active")
  summary   String?
  createdAt DateTime @default(now())

  checkpoints InstitutionalContinuityCheckpoint[]
}

model InstitutionalContinuityCheckpoint {
  id        String   @id @default(cuid())
  planId    String
  plan      InstitutionalContinuityPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title     String
  category  String
  dueAt     DateTime?
  completed Boolean  @default(false)
}

model CivicAuditIndexEntry {
  id          String   @id @default(cuid())
  auditYear   String   @unique
  title       String
  overallScore Float?
  status      String   @default("draft")
  findingsJson Json?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

model FederatedAccountabilityPartner {
  id          String   @id @default(cuid())
  partnerName String
  jurisdiction String?
  scope       String
  status      String   @default("active")
  linkedAt    DateTime @default(now())
}
