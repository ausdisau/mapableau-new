  @@index([sessionId])
}

model Timesheet {
  id               String          @id @default(cuid())
  careShiftId      String          @unique
  careShift        CareShift       @relation(fields: [careShiftId], references: [id], onDelete: Cascade)
  participantId    String
  participant        User            @relation("TimesheetParticipant", fields: [participantId], references: [id])
