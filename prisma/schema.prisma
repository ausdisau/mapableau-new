// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String
  email            String             @unique
  worker           Worker?
  passwordHash     String
  createdAt        DateTime           @default(now())
  sessions         Session[]
  claimedProviders ClaimedProvider[]

  memberships      ProviderUserRole[]
  billingAccounts  BillingAccount[]
  fundingSources   FundingSource[]
  invoices         Invoice[]
  payments         Payment[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]         @relation("AuditLogActor")
}

model Worker {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])

  bio             String?
  qualifications  String?
  languages       Language[]
  availability    WorkerAvailability[]
  specialisations Specialisation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providers WorkerProvider[]
}

model Language {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model WorkerAvailability {
  id             String   @id @default(uuid())
  workerId       String
  worker         Worker   @relation(fields: [workerId], references: [id])
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
}

model Specialisation {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model ClaimedProvider {
  id           String    @id @default(cuid())
  slug         String    @unique
  outletKey    String?   @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  website      String?
  description  String?
  openingHours String?
  suburb       String?
  state        String?
  postcode     String?
  categories   String[]
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Provider {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  description   String?

  website       String?
  email         String?
  phone         String?

  abn           String?
  businessType  String?  // e.g. "Company", "Sole trader", "Partnership"

  ndisRegistered Boolean @default(false)
  ndisNumber     String?

  rating         Float?   // average rating 0–5
  reviewCount    Int      @default(0)

  serviceAreas   String[] @default([]) // geographic areas provider designates they serve, e.g. "Melbourne Metro", "Western Sydney"
  specialisations String[] @default([]) // e.g. "Autism", "Complex Behaviour", "Mental Health"

  services      Service[]
  locations     ServiceLocation[]
  businessHours BusinessHour[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workers WorkerProvider[]
  userRoles ProviderUserRole[]
}

model ProviderUserRole {
  id          String   @id @default(uuid())
  userId      String
  providerId  String
  role        ProviderRole
  assignedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId]) // ensures a user has only one role per provider
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    Provider @relation(fields: [providerId], references: [id])
  providerId  String
}

model ServiceLocation {
  id         String   @id @default(uuid())
  address    String
  city       String?
  state      String?
  postcode   String?
  country    String?

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model BusinessHour {
  id         String   @id @default(uuid())
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model WorkerProvider {
  id         String   @id @default(uuid())
  workerId   String
  providerId String

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  startDate  DateTime?
  endDate    DateTime?

  @@unique([workerId, providerId])
}

// todo: remove because we're using JWT
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProviderRole {
  ADMIN
  MANAGER
  STAFF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// --- MapAble Core Billing ---

enum BillingAccountRole {
  participant
  provider
  employer
  admin
}

enum FundingSourceType {
  ndis_plan_managed
  ndis_self_managed
  private_card
  organisation_invoice
  grant
  other
}

enum InvoiceServiceType {
  care
  transport
  jobs
  marketplace
  subscription
  other
}

enum InvoiceStatus {
  draft
  issued
  pending_payment
  paid
  failed
  refunded
  cancelled
  exported
}

enum PaymentStatus {
  requires_payment
  processing
  succeeded
  failed
  refunded
  disputed
}

enum PaymentMethod {
  stripe_checkout
  stripe_connect
  external_plan_manager
  xero_export
  manual
}

enum PaymentSplitRecipientType {
  provider
  worker
  transport_operator
  mapable_platform
}

enum PaymentSplitStatus {
  pending
  transferred
  failed
  reversed
}

enum SubscriptionPlanCode {
  provider_pro
  employer_pro
  marketplace_featured
  other
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

model BillingAccount {
  id                        String             @id @default(cuid())
  userId                    String
  user                      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                      BillingAccountRole
  stripeCustomerId          String?
  stripeConnectedAccountId  String?
  connectOnboardingComplete Boolean            @default(false)
  defaultFundingSourceId    String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  subscriptions Subscription[]

  @@unique([userId, role])
  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeConnectedAccountId])
}

model FundingSource {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  FundingSourceType
  label                 String
  ndisParticipantNumber String?
  planManagerName       String?
  planManagerEmail      String?
  isDefault             Boolean           @default(false)
  metadata              Json              @default("{}")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  invoices Invoice[]

  @@index([userId])
}

model Invoice {
  id                       String             @id @default(cuid())
  userId                   String
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId               String?
  bookingId                String?
  serviceType              InvoiceServiceType
  status                   InvoiceStatus      @default(draft)
  fundingSourceId          String?
  fundingSource            FundingSource?     @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  currency                 String             @default("AUD")
  subtotalCents            Int
  platformFeeCents         Int                @default(0)
  gstCents                 Int                @default(0)
  totalCents               Int
  ndisLineItem             String?
  ndisClaimable            Boolean            @default(false)
  stripeCheckoutSessionId  String?
  stripePaymentIntentId    String?
  stripeInvoiceId          String?
  xeroExportStatus         String?
  planManagerExportStatus  String?
  dueAt                    DateTime?
  paidAt                   DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([bookingId])
}

model InvoiceLineItem {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description     String
  quantity        Int      @default(1)
  unitAmountCents Int
  totalCents      Int
  ndisLineItem    String?
  gstApplicable   Boolean  @default(false)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([invoiceId])
}

model Payment {
  id                      String        @id @default(cuid())
  invoiceId               String
  invoice                 Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId              String?
  status                  PaymentStatus @default(requires_payment)
  method                  PaymentMethod
  amountCents             Int
  currency                String        @default("AUD")
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeChargeId          String?
  failureReason           String?
  paidAt                  DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  splits PaymentSplit[]

  @@index([invoiceId])
  @@index([userId])
  @@index([status])
}

model PaymentSplit {
  id                      String                    @id @default(cuid())
  paymentId               String
  payment                 Payment                   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  recipientType           PaymentSplitRecipientType
  recipientId             String?
  stripeConnectedAccountId String?
  amountCents             Int
  applicationFeeCents     Int                       @default(0)
  transferId              String?
  status                  PaymentSplitStatus        @default(pending)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([paymentId])
}

model Subscription {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAccountId     String
  billingAccount       BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  planCode             SubscriptionPlanCode
  status               SubscriptionStatus   @default(incomplete)
  stripeCustomerId     String
  stripeSubscriptionId String               @unique
  stripePriceId        String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
  @@index([billingAccountId])
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  processed     Boolean   @default(false)
  payload       Json
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([type])
  @@index([processed])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}