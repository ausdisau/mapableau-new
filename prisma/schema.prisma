model AccessPlace {
  id               String              @id @default(cuid())
  name             String
  category         AccessPlaceCategory @default(other)
  description      String?
  addressText      String?             @map("address_text")
  suburb           String?
  stateOrRegion    String?             @map("state_or_region")
  country          String              @default("AU")
  status           AccessPlaceStatus   @default(draft)
  sourceType       AccessPlaceSourceType @default(user_suggested) @map("source_type")
  sourceReference  String?             @map("source_reference")
  confidence       AccessConfidenceLevel @default(unknown)
  createdById      String?             @map("created_by")
  createdBy        User?               @relation("AccessPlaceCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  location         AccessPlaceLocation?
  features         AccessPlaceFeature[]
  sources          AccessPlaceSource[]
  claims           AccessPlaceClaim[]
  reports          AccessPlaceReport[]
  events           AccessPlaceEvent[]
  reviews          AccessPlaceReview[]
  ratingSummaries  AccessRatingSummary[]
  accreditationAssessments AccessAccreditationAssessment[]
  venueClaims      AccessVenueClaim[]
  venueProfile     AccessVenueProfile?
  importItems      AccessImportItem[]

  @@index([status])
  @@index([suburb, stateOrRegion])
  @@map("access_places")
}

