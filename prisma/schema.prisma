}

model NdisRuleWarning {
  id           String                  @id @default(cuid())
  sourceType   String
  sourceId     String
  warningType  String
  severity     NdisRuleWarningSeverity @default(warning)
  message      String
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime                @default(now())

  @@index([sourceType, sourceId])
}

model SmartContract {
  id                  String              @id @default(cuid())
  code                String              @unique
  name                String
  type                SmartContractType
  version             String              @default("1")
  status              SmartContractStatus @default(draft)
  triggerEvent        String?
  description         String?
  rulesJson           Json                @default("[]")
  requiresHumanApproval Boolean           @default(true)
  createdById         String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

