  threshold       Float?
  passed          Boolean @default(true)
  explanation     String
}

model FairnessReview {
  id              String   @id @default(cuid())
  fairnessCheckId String
  fairnessCheck   FairnessCheck @relation(fields: [fairnessCheckId], references: [id], onDelete: Cascade)
  reviewerId      String
