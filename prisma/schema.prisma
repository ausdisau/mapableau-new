  insurance
  ndis_registration_claim
  worker_screening_policy
  incident_policy
  complaints_policy
  privacy_policy
  service_agreement_template
  vehicle_registration
  driver_licence
  accessibility_training
  manual_reference_check
}

enum VerificationCaseStatus {
  draft
  submitted
  under_review
  more_information_required
  approved
  approved_with_conditions
  rejected
  suspended
  expired
}

model ProviderVerificationCase {
  id               String                 @id @default(cuid())
  organisationId   String
  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  status           VerificationCaseStatus @default(draft)
  submittedAt      DateTime?
  decidedAt        DateTime?
  createdById      String?
  adminOwnerId     String?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  checks     ProviderVerificationCheck[]
