model Attestation {
  id                 String            @id @default(cuid())
  type               AttestationType
  status             AttestationStatus @default(recorded)
  actorUserId        String?
  actorUser            User?             @relation("AttestationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorOrganisationId String?
  participantId      String?
  entityType         String
  entityId           String
  claim              String
  evidenceJson       Json?
  evidenceHash       String?
  contractRunId      String?
  supersededById     String?
  createdAt          DateTime          @default(now())

  @@index([participantId])
  @@index([entityType, entityId])
  @@index([type])
