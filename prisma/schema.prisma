  @@index([tripId, createdAt])
  @@map("transport_route_estimates")
}

model TransportRouteSegment {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    TransportRouteEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  sequence    Int
  fromLat     Float
  fromLng     Float
  toLat       Float
  toLng       Float
  distanceMetres Int?
  durationSeconds Int?

  @@map("transport_route_segments")
}

model TransportRouteOptimisationJob {
  id              String                       @id @default(cuid())
  tripId          String?
  trip            TransportTrip?               @relation(fields: [tripId], references: [id], onDelete: SetNull)
  organisationId  String?
  provider        TransportRoutingProvider
  status          TransportOptimisationJobStatus @default(pending)
  requiresHumanReview Boolean                  @default(true)
  inputPayload    Json?
  errorMessage    String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  results         TransportRouteOptimisationResult[]

  @@map("transport_route_optimisation_jobs")
}

model TransportRouteOptimisationResult {
  id          String   @id @default(cuid())
  jobId       String
  job         TransportRouteOptimisationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  summary     String
  score       Float?
  suggestionPayload Json?
  createdAt   DateTime @default(now())

  @@map("transport_route_optimisation_results")
}

model TransportLiveLocation {
  id        String   @id @default(cuid())
  tripId    String
  trip      TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driverId  String?
  lat       Float
  lng       Float
  recordedAt DateTime @default(now())

  @@index([tripId, recordedAt])
  @@map("transport_live_locations")
}

model TransportEtaEvent {
  id              String   @id @default(cuid())
  tripId          String
  trip            TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  etaMinutes      Int?
  distanceMetres  Int?
  source          String?
  createdAt       DateTime @default(now())

  @@map("transport_eta_events")
}

model TransportPickupPoint {
  id        String   @id @default(cuid())
  tripId    String
  trip      TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  address   String
  suburb    String?
  lat       Float?
  lng       Float?
  notes     String?

  @@map("transport_pickup_points")
}

model TransportDropoffPoint {
  id        String   @id @default(cuid())
  tripId    String
  trip      TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  address   String
  suburb    String?
  lat       Float?
  lng       Float?
  notes     String?

  @@map("transport_dropoff_points")
}

model TransportSafetyCheck {
  id        String   @id @default(cuid())
  tripId    String
  trip      TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  checkType String
  passed    Boolean
  notes     String?
  actorUserId String?
  createdAt DateTime @default(now())

  @@map("transport_safety_checks")
}

model TransportTripEvidence {
  id          String   @id @default(cuid())
  tripId      String
  trip        TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  evidenceType String
  notes       String?
  metadata    Json?
  submittedByUserId String?
  createdAt   DateTime @default(now())

  @@map("transport_trip_evidence")
}

model TransportHandoverRecord {
  id          String   @id @default(cuid())
  tripId      String
  trip        TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  notes       String?
  actorUserId String?
  createdAt   DateTime @default(now())

  @@map("transport_handover_records")
}

model TransportSafetyEvent {
  id          String                     @id @default(cuid())
  tripId      String
  trip        TransportTrip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  severity    TransportSafetyEventSeverity @default(medium)
  category    String
  description String
  reportedByUserId String?
  escalated   Boolean                    @default(false)
  createdAt   DateTime                   @default(now())

  incidentLinks TransportIncidentLink[]

  @@map("transport_safety_events")
}

model TransportIncidentLink {
  id              String   @id @default(cuid())
  tripId          String
  trip            TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  safetyEventId   String?
  safetyEvent     TransportSafetyEvent? @relation(fields: [safetyEventId], references: [id], onDelete: SetNull)
  incidentReportId String?
  incidentReport  IncidentReport? @relation("TransportIncidentLink", fields: [incidentReportId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@map("transport_incident_links")
}

// =========================================================================
// AI-Enabled Case Management
// -------------------------------------------------------------------------
// A Case is a longitudinal record opened by a support coordinator, plan
// manager, or admin for a participant. It binds together notes, tasks and
// links to other entities, and stores AI-generated insights (summary,
// risk classification, next-best-action) generated by a deterministic
// rule-based engine that can be swapped for an LLM backend.
// =========================================================================

enum CaseStatus {
  open
  monitoring
  on_hold
  closed
}

enum CasePriority {
  low
  medium
  high
  urgent
}

enum CaseCategory {
  intake
  goal_planning
  service_coordination
  funding_review
  safeguarding
  housing
  health
  employment
  education
  legal
  other
}

enum CaseRiskLevel {
  low
  moderate
  elevated
  high
  critical
}

enum CaseTaskStatus {
  pending
  in_progress
  blocked
  done
  cancelled
}

enum CaseLinkType {
  booking
  incident
  support_ticket
  document
  funding_source
  service_agreement
  external
  note
}

enum CaseAIInsightKind {
  summary
  risk_assessment
  next_action
  search_result
}

model Case {
  id                String       @id @default(cuid())
  reference         String       @unique
  title             String
  description       String       @default("")
  status            CaseStatus   @default(open)
  priority          CasePriority @default(medium)
  category          CaseCategory @default(other)
  riskLevel         CaseRiskLevel @default(low)

  participantId     String?
  participant       User?        @relation("CaseParticipant", fields: [participantId], references: [id], onDelete: SetNull)
  assignedToId      String?
  assignedTo        User?        @relation("CaseAssignedToUser", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User         @relation("CaseCreatedByUser", fields: [createdById], references: [id])
  closedById        String?
  closedBy          User?        @relation("CaseClosedByUser", fields: [closedById], references: [id], onDelete: SetNull)

  organisationId    String?
  goalsJson         Json?
  tagsJson          Json?
  aiOptOut          Boolean      @default(false)
  lastAiRunAt       DateTime?

  openedAt          DateTime     @default(now())
  dueAt             DateTime?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  notes             CaseNote[]
  tasks             CaseTask[]
  links             CaseLink[]
  insights          CaseAIInsight[]

  @@index([participantId])
  @@index([assignedToId])
  @@index([status])
  @@map("cases")
}

model CaseNote {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("CaseNoteAuthor", fields: [authorId], references: [id])
  body        String
  isPrivate   Boolean  @default(false)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([caseId])
  @@map("case_notes")
}

model CaseTask {
  id            String         @id @default(cuid())
  caseId        String
  case          Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  details       String?
  status        CaseTaskStatus @default(pending)
  priority      CasePriority   @default(medium)
  assigneeId    String?
  assignee      User?          @relation("CaseTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User           @relation("CaseTaskCreator", fields: [createdById], references: [id])
  completedById String?
  completedBy   User?          @relation("CaseTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  aiSuggested   Boolean        @default(false)
  dueAt         DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([caseId])
  @@index([assigneeId])
  @@map("case_tasks")
}

model CaseLink {
  id          String       @id @default(cuid())
  caseId      String
  case        Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  linkType    CaseLinkType
  targetId    String?
  label       String
  url         String?
  notes       String?
  createdById String
  createdBy   User         @relation("CaseLinkCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([caseId])
  @@map("case_links")
}

model CaseAIInsight {
  id              String            @id @default(cuid())
  caseId          String
  case            Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind            CaseAIInsightKind
  engine          String            @default("rules-v1")
  summary         String
  detailJson      Json?
  confidence      Float             @default(0.5)
  requiresReview  Boolean           @default(true)
  acknowledgedAt  DateTime?
  acknowledgedById String?
  requestedById   String
  requestedBy     User              @relation("CaseAIInsightRequestedBy", fields: [requestedById], references: [id])
  createdAt       DateTime          @default(now())

  @@index([caseId])
  @@index([kind])
  @@map("case_ai_insights")
}

// --- Platform provider patterns (MVP) ---

enum OnboardingRole {
  participant
  worker
  provider
}

enum ConsentShareMode {
  once
  always_for_service
  deny
}

enum ConsentRecipientType {
  organisation
  worker
  plan_manager
  support_coordinator
  platform
}

enum BillingAdminApprovalStatus {
  draft
  pending_approval
  approved
  disputed
}

enum BookingGraphEntityType {
  care_shift
  transport_booking
  booking_segment
  calendar_event
}

enum BookingGraphDependencyType {
  must_finish_before
  requires_buffer
  same_worker_exclusive
}

enum TrustSafetyQueueSource {
  incident
  complaint
  disputed_service_log
  repeated_cancellation
  worker_boundary
}

enum TrustSafetyQueueStatus {
  open
  acknowledged
  investigating
  escalated
  resolved
  closed
}

enum AgentRunType {
  intake
  care_plan
  transport
  matching
  billing
  guardrail
  safeguarding_triage
  feedback
  category_classifier
}

enum AgentRunStatus {
  started
  completed
  failed
  reviewed
  blocked
}

enum AgentRiskTier {
  low
  medium
  high
  critical
}

model OnboardingProfile {
  id                       String         @id @default(cuid())
  role                     OnboardingRole
  userId                   String?
  user                     User?          @relation("OnboardingProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  organisationId           String?
  organisation             Organisation?  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  workerProfileId          String?        @unique
  workerProfile            WorkerProfile? @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  profileCompletenessScore Int            @default(0)
  readyToMatch             Boolean        @default(false)
  checklistJson            Json           @default("[]")
  lastEvaluatedAt          DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@unique([userId, role])
  @@unique([organisationId, role])
  @@index([organisationId, role])
  @@map("onboarding_profiles")
}

model SupportJourneySession {
  id                      String   @id @default(cuid())
  participantId           String
  participant             User     @relation("SupportJourneyParticipant", fields: [participantId], references: [id], onDelete: Cascade)
  sessionId               String
  version                 Int      @default(1)
  graphJson               Json     @default("{}")
  pendingConfirmationGate String?
  careRequestId           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([participantId, sessionId])
  @@index([participantId])
  @@map("support_journey_sessions")
}

model BookingGraphNode {
  id         String                 @id @default(cuid())
  entityType BookingGraphEntityType
  entityId   String
  label      String?
  metadata   Json?
  createdAt  DateTime               @default(now())

  edgesFrom BookingGraphEdge[] @relation("GraphEdgeFrom")
  edgesTo   BookingGraphEdge[] @relation("GraphEdgeTo")

  @@unique([entityType, entityId])
  @@map("booking_graph_nodes")
}

model BookingGraphEdge {
  id               String                     @id @default(cuid())
  fromNodeId       String
  fromNode         BookingGraphNode           @relation("GraphEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId         String
  toNode           BookingGraphNode           @relation("GraphEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  dependencyType   BookingGraphDependencyType
  bufferMinutes    Int?
  notes            String?
  createdAt        DateTime                   @default(now())

  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("booking_graph_edges")
}

model TrustSafetyQueueItem {
  id               String                 @id @default(cuid())
  source           TrustSafetyQueueSource
  status           TrustSafetyQueueStatus @default(open)
  escalationLevel  Int                    @default(0)
  title            String
  summary          String?
  participantId    String?
  organisationId   String?
  incidentId       String?
  complaintId      String?
  entityType       String?
  entityId         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?

  @@index([status, source])
  @@index([participantId])
  @@map("trust_safety_queue_items")
}

model Complaint {
  id              String                 @id @default(cuid())
  participantId   String?
  organisationId  String?
  reportedById    String
  reportedBy      User                   @relation("ComplaintReportedBy", fields: [reportedById], references: [id])
  title           String
  description     String
  status          TrustSafetyQueueStatus @default(open)
  escalationLevel Int                    @default(0)
  source          String                 @default("participant")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status])
  @@map("complaints")
}

model AgentRun {
  id                            String         @id @default(cuid())
  agentType                     AgentRunType
  status                        AgentRunStatus @default(started)
  riskTier                      AgentRiskTier  @default(low)
  humanReviewRequired           Boolean        @default(false)
  participantConfirmationRequired Boolean      @default(false)
  inputSummary                  Json?
  outputSummary                 Json?
  toolsCalled                   Json           @default("[]")
  guardrailsTriggered           Json           @default("[]")
  participantId                 String?
  careRequestId                 String?
  matchRunId                    String?
  aiMatchRunId                  String?
  billingInvoiceId              String?
  auditEventId                  String?
  reviewedById                  String?
  reviewedAt                    DateTime?
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@index([agentType, status])
  @@index([participantId])
  @@map("agent_runs")
}

model ReliabilitySnapshot {
  id                 String   @id @default(cuid())
  workerProfileId    String?
  organisationId     String?
  periodStart        DateTime
  periodEnd          DateTime
  completionRate     Float    @default(0)
  lateRate           Float    @default(0)
  cancellationRate   Float    @default(0)
  incidentCount      Int      @default(0)
  complaintCount     Int      @default(0)
  responseTimeP50Ms  Int?
  advisorySummary    String?
  metadata           Json?
  createdAt          DateTime @default(now())

  @@index([workerProfileId, periodEnd])
  @@index([organisationId, periodEnd])
  @@map("reliability_snapshots")
}

model InvoiceLineEvidence {
  id              String         @id @default(cuid())
  lineItemId      String
  lineItem        BillingInvoiceLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  careServiceLogId String?
  careShiftId     String?
  participantSafeDescription String
  createdAt       DateTime       @default(now())

  @@index([lineItemId])
  @@map("invoice_line_evidence")
}
