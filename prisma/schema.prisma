// MapAble — unified Prisma schema (single source of truth).
// All domain models live in this file. Phase-specific extension files were
// removed; use migrations under prisma/migrations/ for history.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String             @id @default(cuid())
  name                   String
  email                  String             @unique
  phone                  String?
  timezone               String             @default("Australia/Sydney")
  locale                 String             @default("en-AU")
  preferredContactMethod PreferredContactMethod @default(email)
  primaryRole            MapAbleUserRole    @default(participant)
  worker                 Worker?
  passwordHash           String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  sessions               Session[]
  claimedProviders       ClaimedProvider[]
  passkeyCredentials     PasskeyCredential[]

  memberships            ProviderUserRole[]
  roleAssignments        UserRoleAssignment[]
  participantProfile     ParticipantProfile?
  accessibilityProfile   AccessibilityProfile?
  organisationMemberships OrganisationMember[]
  consentsAsSubject      ConsentRecord[]    @relation("ConsentSubject")
  consentsGranted        ConsentRecord[]    @relation("ConsentGrantedToUser")
  consentsCreated        ConsentRecord[]    @relation("ConsentCreatedBy")
  consentsRevoked        ConsentRecord[]    @relation("ConsentRevokedBy")
  notificationPreferences NotificationPreference[]
  notifications          Notification[]
  auditEvents            AuditEvent[]       @relation("AuditActor")
  bookingsCreated        Booking[]          @relation("BookingCreatedBy")
  bookingsAsParticipant  Booking[]          @relation("BookingParticipant")
  bookingsAssignedWorker Booking[]          @relation("BookingAssignedWorker")
  bookingsAssignedDriver Booking[]          @relation("BookingAssignedDriver")
  conversationsCreated   Conversation[]     @relation("ConversationCreatedBy")
  conversationParticipants ConversationParticipant[]
  messagesSent           Message[]          @relation("MessageSender")
  messageReadReceipts    MessageReadReceipt[]
  ticketsCreated         SupportTicket[]    @relation("TicketCreatedBy")
  ticketsAssigned        SupportTicket[]    @relation("TicketAssignedAdmin")
  ticketComments         SupportTicketComment[]
  documentsUploaded      Document[]         @relation("DocumentUploadedBy")
  fundingSources         ParticipantFundingSource[] @relation("ParticipantFundingSources")
  fundingSourcesCreated  ParticipantFundingSource[] @relation("FundingSourceCreatedBy")
  invoicesAsParticipant  Invoice[]          @relation("InvoiceParticipant")
  invoicesCreated        Invoice[]          @relation("InvoiceCreatedBy")
  preflightResultsCreated BillingPreflightResult[]
  stripeCustomerLink     StripeCustomerLink?
  bookingTimelineEvents  BookingTimelineEvent[]

  careRequests              CareRequest[]      @relation("CareRequestParticipant")
  careRequestsCreated       CareRequest[]      @relation("CareRequestCreatedBy")
  careBookings              CareBooking[]      @relation("CareBookingParticipant")
  careShifts                CareShift[]        @relation("CareShiftParticipant")
  careShiftsApproved        CareShift[]        @relation("CareShiftApprovedBy")
  careServiceLogsConfirmed  CareServiceLog[]   @relation("CareServiceLogConfirmedBy")
  careParticipantPreferences CareParticipantPreference[]
  careAccessNeeds           CareAccessNeed[]
  careRiskFlags             CareRiskFlag[]
  careLivingAloneSafeguards CareLivingAloneSafeguard[]
  supportProfile            SupportProfile?
  workerProfiles            WorkerProfile[]    @relation("WorkerProfileUser")
  onboardingProfiles        OnboardingProfile[] @relation("OnboardingProfileUser")
  supportJourneySessions    SupportJourneySession[] @relation("SupportJourneyParticipant")
  complaintsReported        Complaint[]        @relation("ComplaintReportedBy")
  driverProfiles            DriverProfile[]    @relation("DriverProfileUser")
  transportBookings         TransportBooking[] @relation("TransportBookingParticipant")
  jobsCreated               Job[]              @relation("JobCreatedBy")
  jobApplications           JobApplication[]   @relation("JobApplicationParticipant")
  calendarEvents            CalendarEvent[]    @relation("CalendarEventParticipant")
  calendarEventsCreated     CalendarEvent[]    @relation("CalendarEventCreatedBy")
  matchRunsRequested        MatchRun[]         @relation("MatchRunRequestedBy")
  incidentsReported         IncidentReport[]   @relation("IncidentReportedBy")
  incidentsOwned            IncidentReport[]   @relation("IncidentAdminOwner")
  serviceAgreementsParticipant ServiceAgreement[] @relation("ServiceAgreementParticipant")
  serviceAgreementsCreated  ServiceAgreement[] @relation("ServiceAgreementCreatedBy")
  attestationsAsActor       Attestation[]      @relation("AttestationActor")
  timesheetsAsParticipant   Timesheet[]        @relation("TimesheetParticipant")

  billingAccounts           BillingAccount[]       @relation("BillingAccounts")
  billingFundingSources     BillingFundingSource[] @relation("BillingFundingSources")
  billingInvoices           BillingInvoice[]       @relation("BillingInvoices")
  billingPayments           BillingPayment[]       @relation("BillingPayments")
  billingSubscriptions      BillingSubscription[]  @relation("BillingSubscriptions")
  ndisClaimLinesParticipant NdisClaimLine[]        @relation("NdisClaimLinesParticipant")
  ndisInvoicesParticipant   NdisInvoice[]          @relation("NdisInvoicesParticipant")
  participantProviderRelationships ParticipantProviderRelationship[] @relation("ParticipantProviderRelationships")
  ndisDeliveryAuthorizationsParticipant NdisServiceDeliveryAuthorization[] @relation("NdisDeliveryAuthParticipant")
  ndisDeliveryEventsParticipant NdisServiceDeliveryEvent[] @relation("NdisDeliveryEventParticipant")

  accessPlacesCreated       AccessPlace[]          @relation("AccessPlaceCreatedBy")
  accessPlaceClaims         AccessPlaceClaim[]     @relation("AccessPlaceClaimUser")
  accessPlaceReports        AccessPlaceReport[]    @relation("AccessPlaceReportReporter")
  accessPlaceReviews        AccessPlaceReview[]    @relation("AccessPlaceReviewAuthor")
  accessImportsCreated      AccessImportJob[]      @relation("AccessImportCreatedBy")
  accessAccreditationAssessments AccessAccreditationAssessment[] @relation("AccessAccreditationAssessor")
  accessVenueClaims         AccessVenueClaim[]     @relation("AccessVenueClaimUser")
  accessVenueProfiles       AccessVenueProfile[]   @relation("AccessVenueOwner")
  accessVenueReviewResponses AccessVenueReviewResponse[] @relation("AccessVenueResponseAuthor")
  accessAccreditationRequests AccessAccreditationRequest[] @relation("AccessAccreditationRequestUser")
  accessModerationDecisions AccessModerationDecision[] @relation("AccessModerator")
  accessContentReports      AccessContentReport[]  @relation("AccessContentReporter")
  dataAccessLogs            DataAccessLog[]        @relation("DataAccessActor")
  transportTripRequests     TransportTripRequest[] @relation("TransportTripRequestParticipant")
  transportTrips            TransportTrip[]        @relation("TransportTripParticipant")
  transportTripEvents       TransportTripEvent[]   @relation("TransportTripEventActor")

  // AI-enabled case management
  caseManagementOwned       Case[]                 @relation("CaseAssignedToUser")
  caseManagementCreated     Case[]                 @relation("CaseCreatedByUser")
  caseManagementClosed      Case[]                 @relation("CaseClosedByUser")
  caseManagementParticipant Case[]                 @relation("CaseParticipant")
  caseNotesAuthored         CaseNote[]             @relation("CaseNoteAuthor")
  caseTasksAssigned         CaseTask[]             @relation("CaseTaskAssignee")
  caseTasksCreated          CaseTask[]             @relation("CaseTaskCreator")
  caseTasksCompleted        CaseTask[]             @relation("CaseTaskCompletedBy")
  caseLinksCreated          CaseLink[]             @relation("CaseLinkCreatedBy")
  caseAiInsightsRequested   CaseAIInsight[]        @relation("CaseAIInsightRequestedBy")
}

model PasskeyCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   String[]  @default([])
  deviceType   String?
  backedUp     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model Worker {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])

  bio             String?
  qualifications  String?
  languages       Language[]
  availability    WorkerAvailability[]
  specialisations Specialisation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providers WorkerProvider[]
}

model Language {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model WorkerAvailability {
  id             String   @id @default(uuid())
  workerId       String
  worker         Worker   @relation(fields: [workerId], references: [id])
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
}

model Specialisation {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model ClaimedProvider {
  id           String    @id @default(cuid())
  slug         String    @unique
  outletKey    String?   @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  website      String?
  description  String?
  openingHours String?
  suburb       String?
  state        String?
  postcode     String?
  categories   String[]
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProviderProfile {
  id              String   @id @default(cuid())
  name            String
  slug            String?  @unique
  legacyProviderId String?
  suburb          String?
  state           String?
  postcode        String?
  isVerified      Boolean  @default(false)
  isSearchVisible Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  services ProviderProfileService[]

  @@index([name])
  @@index([isSearchVisible, isVerified])
  @@map("provider_profiles")
}

/// NDIS provider finder export (list-providers.json / provider-outlets.json).
model ProviderOutletRegistry {
  id           String   @id
  abn          String
  name         String
  slug         String?
  outletKey    String?  @map("outlet_key")
  outletName   String?  @map("outlet_name")
  flag         String?
  active       Boolean  @default(false)
  phone        String?
  website      String?
  email        String?
  address      String?
  headOffice   String?  @map("head_office")
  state        String
  postcode     String?
  latitude     Float?
  longitude    Float?
  regGroup     Int[]    @default([]) @map("reg_group")
  openingHours String?  @map("opening_hours")
  professions  String?
  raw          Json
  sourceDate   String?  @map("source_date")
  importedAt   DateTime @default(now()) @map("imported_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([state])
  @@index([abn])
  @@index([name])
  @@index([outletKey])
  @@map("provider_outlets")
}

/// NDIS provider finder directory ingest (list-providers.json); not MapAble-verified registration.
model NdisProviderIngestionRun {
  id            String    @id @default(uuid()) @db.Uuid
  sourceUrl     String    @map("source_url")
  sourceHash    String    @map("source_hash")
  providerCount Int       @map("provider_count")
  status        String
  errorMessage  String?   @map("error_message")
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)

  @@index([startedAt])
  @@index([status])
  @@map("ndis_provider_ingestion_runs")
}

model NdisProvider {
  sourceId           String    @id @map("source_id")
  providerName       String    @map("provider_name")
  legalName          String?   @map("legal_name")
  abn                String?
  registrationNumber String?   @map("registration_number")
  phone              String?
  email              String?
  website            String?
  address            String?
  suburb             String?
  state              String?
  postcode           String?
  latitude           Float?
  longitude          Float?
  services           String[]  @default([])
  registrationGroups String[]  @default([]) @map("registration_groups")
  raw                Json
  rawHash            String    @map("raw_hash")
  sourceUrl          String    @map("source_url")
  sourceUpdatedAt    DateTime? @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt         DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([state])
  @@index([postcode])
  @@map("ndis_providers")
}

model ProviderProfileService {
  id                String          @id @default(cuid())
  providerProfileId String
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)
  name              String

  @@index([providerProfileId])
  @@map("provider_services")
}

model ServiceCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  keywords  String[] @default([])
  createdAt DateTime @default(now())

  providerServices ProviderProfileService[]

  @@index([name])
  @@map("service_categories")
}

model SearchAccessibilityFeature {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  keywords  String[] @default([])
  createdAt DateTime @default(now())

  @@index([label])
  @@map("accessibility_features")
}

model SearchableLocation {
  id          String   @id @default(cuid())
  displayName String
  suburb      String?
  state       String?
  postcode    String?
  country     String   @default("AU")
  createdAt   DateTime @default(now())

  @@index([suburb])
  @@index([postcode])
  @@index([displayName])
  @@map("searchable_locations")
}

model PopularSearch {
  id        String   @id @default(cuid())
  query     String
  context   String   @default("all")
  weight    Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([query, context])
  @@index([context, weight])
  @@map("popular_searches")
}

model SearchLanguage {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  keywords  String[] @default([])
  createdAt DateTime @default(now())

  @@map("search_languages")
}

model Provider {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  description   String?

  website       String?
  email         String?
  phone         String?

  abn           String?
  businessType  String?  // e.g. "Company", "Sole trader", "Partnership"

  ndisRegistered Boolean @default(false)
  ndisNumber     String?

  rating         Float?   // average rating 0–5
  reviewCount    Int      @default(0)

  serviceAreas   String[] @default([]) // geographic areas provider designates they serve, e.g. "Melbourne Metro", "Western Sydney"
  specialisations String[] @default([]) // e.g. "Autism", "Complex Behaviour", "Mental Health"

  services      Service[]
  locations     ServiceLocation[]
  businessHours BusinessHour[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workers WorkerProvider[]
  userRoles ProviderUserRole[]
}

model ProviderUserRole {
  id          String   @id @default(uuid())
  userId      String
  providerId  String
  role        ProviderRole
  assignedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId]) // ensures a user has only one role per provider
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    Provider @relation(fields: [providerId], references: [id])
  providerId  String
}

model ServiceLocation {
  id         String   @id @default(uuid())
  address    String
  city       String?
  state      String?
  postcode   String?
  country    String?

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model BusinessHour {
  id         String   @id @default(uuid())
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model WorkerProvider {
  id         String   @id @default(uuid())
  workerId   String
  providerId String

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  startDate  DateTime?
  endDate    DateTime?

  @@unique([workerId, providerId])
}

// todo: remove because we're using JWT
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProviderRole {
  ADMIN
  MANAGER
  STAFF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PreferredContactMethod {
  email
  phone
  sms
}

enum MapAbleUserRole {
  participant
  family_member
  support_coordinator
  support_worker
  provider_admin
  transport_operator
  driver
  employer
  plan_manager
  mapable_admin
}

enum OrganisationType {
  care_provider
  transport_provider
  plan_manager
  support_coordination
  employer
  community_partner
  mapable_internal
}

enum VerificationStatus {
  not_started
  pending_review
  verified
  rejected
  suspended
}

enum OrganisationStatus {
  active
  inactive
  archived
}

enum ConsentScope {
  profile_read
  accessibility_read
  booking_read
  booking_manage
  messages_send
  billing_read
  support_coordination_access
  plan_manager_invoice_access
  transport_accessibility_share
  transport_trip_access
  care_accessibility_share
  support_profile_read
}

enum ConsentStatus {
  active
  expired
  revoked
  pending
}

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum NotificationCategory {
  booking
  profile
  consent
  provider
  billing
  support
  safeguarding
  system
}

enum BookingType {
  care
  transport
  care_transport
}

enum BookingStatus {
  draft
  requested
  awaiting_provider_acceptance
  confirmed
  in_progress
  completed
  cancelled
  disputed
}

model UserRoleAssignment {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MapAbleUserRole
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@unique([userId, role])
}

model ParticipantProfile {
  id                       String                 @id @default(cuid())
  userId                   String                 @unique
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName              String
  preferredName            String?
  dateOfBirth              DateTime?
  ndisParticipantNumberEnc String?
  primaryContactMethod     PreferredContactMethod @default(email)
  emergencyContact         Json?
  supportCoordinatorContact Json?
  planManagerContact       Json?
  homeSuburb               String?
  homeState                String?
  timezone                 String                 @default("Australia/Sydney")
  participantNotes         String?
  adminNotes               String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
}

model AccessibilityProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobilityNeeds            Json     @default("[]")
  communicationPreferences Json     @default("[]")
  sensoryPreferences       Json     @default("{}")
  cognitivePreferences     Json     @default("{}")
  transportRequirements    Json     @default("{}")
  digitalPreferences       Json     @default("{}")
  shareWithProviders       Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Organisation {
  id                      String             @id @default(cuid())
  name                    String
  abn                     String?
  organisationType        OrganisationType
  contactEmail            String?
  contactPhone            String?
  website                 String?
  address                 String?
  serviceRegions          String[]           @default([])
  status                  OrganisationStatus @default(active)
  verificationStatus      VerificationStatus @default(not_started)
  ndisRegistrationClaimed Boolean            @default(false)
  ndisRegistrationNumber  String?
  insuranceStatus         String?
  notes                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  members     OrganisationMember[]
  consents    ConsentRecord[]
  bookings    Booking[]
  auditEvents AuditEvent[]
  invoices    Invoice[]
  billingInvoices BillingInvoice[] @relation("BillingInvoiceProvider")
  ndiaProviderClaims NdiaProviderClaim[]
  ndisClaimBatches       NdisClaimBatch[]
  ndisClaimLines         NdisClaimLine[]
  ndisInvoices           NdisInvoice[]
  participantProviderRelationships ParticipantProviderRelationship[]
  ndisDeliveryAuthorizations NdisServiceDeliveryAuthorization[]
  ndisDeliveryEvents         NdisServiceDeliveryEvent[]

  careRequests           CareRequest[]
  careBookings           CareBooking[]
  careShifts             CareShift[]
  careRosterAssignments  CareRosterAssignment[]
  careInvoiceLinks       CareInvoiceLink[]
  workerProfiles         WorkerProfile[]
  capacityBlocks         CapacityBlock[]
  vehicles               Vehicle[]
  driverProfiles         DriverProfile[]
  transportBookings      TransportBooking[] @relation("TransportOperator")
  employerJobs           Job[]              @relation("EmployerJobs")
  calendarEvents         CalendarEvent[]
  availabilityWindows    AvailabilityWindow[]
  timesheets             Timesheet[]
  serviceAgreements      ServiceAgreement[]
  incidentReports        IncidentReport[]
  verificationCases      ProviderVerificationCase[]
  onboardingProfiles     OnboardingProfile[]
  transportTripRequests  TransportTripRequest[] @relation("TransportTripRequestProvider")
  transportTrips         TransportTrip[]        @relation("TransportTripProvider")
  transportDrivers       TransportDriver[]      @relation("TransportDrivers")
  transportVehicles      TransportVehicle[]     @relation("TransportVehicles")
  rideRuns               RideRun[]              @relation("RideRuns")
}

model OrganisationMember {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role           MapAbleUserRole @default(provider_admin)
  createdAt      DateTime        @default(now())

  @@unique([userId, organisationId])
}

model ConsentRecord {
  id                      String        @id @default(cuid())
  subjectUserId           String
  subjectUser             User          @relation("ConsentSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  grantedToUserId         String?
  grantedToUser           User?         @relation("ConsentGrantedToUser", fields: [grantedToUserId], references: [id], onDelete: SetNull)
  grantedToOrganisationId String?
  grantedToOrganisation   Organisation? @relation(fields: [grantedToOrganisationId], references: [id], onDelete: SetNull)
  scope                   ConsentScope
  purpose                 String
  status                  ConsentStatus @default(active)
  expiryDate              DateTime?
  createdById             String
  createdBy               User          @relation("ConsentCreatedBy", fields: [createdById], references: [id])
  revokedById             String?
  revokedBy               User?         @relation("ConsentRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)
  revokedAt               DateTime?
  shareMode               ConsentShareMode?
  recipientType           ConsentRecipientType?
  dataScope               Json?
  sourceAction            String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([subjectUserId, status])
  @@index([grantedToOrganisationId])
}

model NotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  channel   NotificationChannel
  enabled   Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([userId, category, channel])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt])
}

model AuditEvent {
  id             String          @id @default(cuid())
  actorUserId    String?
  actorUser      User?           @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole      MapAbleUserRole?
  action         String
  entityType     String
  entityId       String?
  participantId  String?
  organisationId String?
  organisation   Organisation?   @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())

  @@index([action])
  @@index([participantId])
  @@index([createdAt])
}

model Booking {
  id                     String        @id @default(cuid())
  participantId          String
  participant            User          @relation("BookingParticipant", fields: [participantId], references: [id])
  bookingType            BookingType
  status                 BookingStatus @default(draft)
  requestedStart         DateTime
  requestedEnd           DateTime?
  pickupAddress          String?
  dropoffAddress         String?
  careLocation           String?
  accessibilitySummary   String?
  participantNotes       String?
  providerNotes          String?
  assignedOrganisationId String?
  assignedOrganisation   Organisation? @relation(fields: [assignedOrganisationId], references: [id], onDelete: SetNull)
  assignedWorkerId       String?
