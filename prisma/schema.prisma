  disputedAt               DateTime?
  disputeReason            String?
  anomalyFlags             Json?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  lineItems BillingInvoiceLineItem[]
  payments  BillingPayment[]

  @@index([userId, status])
  @@index([providerId])
  @@index([bookingId])
  @@index([stripeCheckoutSessionId])
  @@index([adminApprovalStatus])
}

