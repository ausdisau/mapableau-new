  cataloguePrices   NdisSupportItemPrice[]

  @@index([active])
}

model NdisLineItemSuggestion {
  id              String   @id @default(cuid())
  sourceType      String
  sourceId        String
  supportItemId   String?
  supportItem     NdisSupportItem? @relation(fields: [supportItemId], references: [id], onDelete: SetNull)
  confidence      Float    @default(0.5)
  explanation     String
  acceptedById    String?
  acceptedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  createdAt       DateTime @default(now())

