// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(cuid())
  name                   String
  email                  String             @unique
  phone                  String?
  timezone               String             @default("Australia/Sydney")
  locale                 String             @default("en-AU")
  preferredContactMethod PreferredContactMethod @default(email)
  primaryRole            MapAbleUserRole    @default(participant)
  worker                 Worker?
  passwordHash           String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  sessions               Session[]
  claimedProviders       ClaimedProvider[]

  memberships            ProviderUserRole[]
  roleAssignments        UserRoleAssignment[]
  participantProfile     ParticipantProfile?
  accessibilityProfile   AccessibilityProfile?
  organisationMemberships OrganisationMember[]
  consentsAsSubject      ConsentRecord[]    @relation("ConsentSubject")
  consentsGranted        ConsentRecord[]    @relation("ConsentGrantedToUser")
  consentsCreated        ConsentRecord[]    @relation("ConsentCreatedBy")
  consentsRevoked        ConsentRecord[]    @relation("ConsentRevokedBy")
  notificationPreferences NotificationPreference[]
  notifications          Notification[]
  auditEvents            AuditEvent[]       @relation("AuditActor")
  bookingsCreated        Booking[]          @relation("BookingCreatedBy")
  bookingsAsParticipant  Booking[]          @relation("BookingParticipant")
  bookingsAssignedWorker Booking[]          @relation("BookingAssignedWorker")
  bookingsAssignedDriver Booking[]          @relation("BookingAssignedDriver")
  conversationsCreated   Conversation[]     @relation("ConversationCreatedBy")
  conversationParticipants ConversationParticipant[]
  messagesSent           Message[]          @relation("MessageSender")
  messageReadReceipts    MessageReadReceipt[]
  ticketsCreated         SupportTicket[]    @relation("TicketCreatedBy")
  ticketsAssigned        SupportTicket[]    @relation("TicketAssignedAdmin")
  ticketComments         SupportTicketComment[]
  documentsUploaded      Document[]         @relation("DocumentUploadedBy")
  fundingSources         ParticipantFundingSource[] @relation("ParticipantFundingSources")
  fundingSourcesCreated  ParticipantFundingSource[] @relation("FundingSourceCreatedBy")
  invoicesAsParticipant  Invoice[]          @relation("InvoiceParticipant")
  invoicesCreated        Invoice[]          @relation("InvoiceCreatedBy")
  preflightResultsCreated BillingPreflightResult[]
  stripeCustomerLink     StripeCustomerLink?
  bookingTimelineEvents  BookingTimelineEvent[]

  careRequests              CareRequest[]      @relation("CareRequestParticipant")
  careRequestsCreated       CareRequest[]      @relation("CareRequestCreatedBy")
  careShifts                CareShift[]        @relation("CareShiftParticipant")
  careShiftsApproved        CareShift[]        @relation("CareShiftApprovedBy")
  workerProfiles            WorkerProfile[]    @relation("WorkerProfileUser")
  driverProfiles            DriverProfile[]    @relation("DriverProfileUser")
  transportBookings         TransportBooking[] @relation("TransportBookingParticipant")
  jobsCreated               Job[]              @relation("JobCreatedBy")
  jobApplications           JobApplication[]   @relation("JobApplicationParticipant")
  calendarEvents            CalendarEvent[]    @relation("CalendarEventParticipant")
  calendarEventsCreated     CalendarEvent[]    @relation("CalendarEventCreatedBy")
}

model Worker {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])

  bio             String?
  qualifications  String?
  languages       Language[]
  availability    WorkerAvailability[]
  specialisations Specialisation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providers WorkerProvider[]
}

model Language {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model WorkerAvailability {
  id             String   @id @default(uuid())
  workerId       String
  worker         Worker   @relation(fields: [workerId], references: [id])
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
}

model Specialisation {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model ClaimedProvider {
  id           String    @id @default(cuid())
  slug         String    @unique
  outletKey    String?   @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  website      String?
  description  String?
  openingHours String?
  suburb       String?
  state        String?
  postcode     String?
  categories   String[]
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Provider {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  description   String?

  website       String?
  email         String?
  phone         String?

  abn           String?
  businessType  String?  // e.g. "Company", "Sole trader", "Partnership"

  ndisRegistered Boolean @default(false)
  ndisNumber     String?

  rating         Float?   // average rating 0–5
  reviewCount    Int      @default(0)

  serviceAreas   String[] @default([]) // geographic areas provider designates they serve, e.g. "Melbourne Metro", "Western Sydney"
  specialisations String[] @default([]) // e.g. "Autism", "Complex Behaviour", "Mental Health"

  services      Service[]
  locations     ServiceLocation[]
  businessHours BusinessHour[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workers WorkerProvider[]
  userRoles ProviderUserRole[]
}

model ProviderUserRole {
  id          String   @id @default(uuid())
  userId      String
  providerId  String
  role        ProviderRole
  assignedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId]) // ensures a user has only one role per provider
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    Provider @relation(fields: [providerId], references: [id])
  providerId  String
}

model ServiceLocation {
  id         String   @id @default(uuid())
  address    String
  city       String?
  state      String?
  postcode   String?
  country    String?

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model BusinessHour {
  id         String   @id @default(uuid())
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model WorkerProvider {
  id         String   @id @default(uuid())
  workerId   String
  providerId String

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  startDate  DateTime?
  endDate    DateTime?

  @@unique([workerId, providerId])
}

// todo: remove because we're using JWT
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProviderRole {
  ADMIN
  MANAGER
  STAFF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PreferredContactMethod {
  email
  phone
  sms
}

enum MapAbleUserRole {
  participant
  family_member
  support_coordinator
  support_worker
  provider_admin
  transport_operator
  driver
  employer
  plan_manager
  mapable_admin
}

enum OrganisationType {
  care_provider
  transport_provider
  plan_manager
  support_coordination
  employer
  community_partner
  mapable_internal
}

enum VerificationStatus {
  not_started
  pending_review
  verified
  rejected
  suspended
}

enum OrganisationStatus {
  active
  inactive
  archived
}

enum ConsentScope {
  profile_read
  accessibility_read
  booking_read
  booking_manage
  messages_send
  billing_read
  support_coordination_access
  plan_manager_invoice_access
  transport_accessibility_share
  care_accessibility_share
}

enum ConsentStatus {
  active
  expired
  revoked
  pending
}

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum NotificationCategory {
  booking
  profile
  consent
  provider
  billing
  support
  safeguarding
  system
}

enum BookingType {
  care
  transport
  care_transport
}

enum BookingStatus {
  draft
  requested
  awaiting_provider_acceptance
  confirmed
  in_progress
  completed
  cancelled
  disputed
}

model UserRoleAssignment {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MapAbleUserRole
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@unique([userId, role])
}

model ParticipantProfile {
  id                       String                 @id @default(cuid())
  userId                   String                 @unique
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName              String
  preferredName            String?
  dateOfBirth              DateTime?
  ndisParticipantNumberEnc String?
  primaryContactMethod     PreferredContactMethod @default(email)
  emergencyContact         Json?
  supportCoordinatorContact Json?
  planManagerContact       Json?
  homeSuburb               String?
  homeState                String?
  timezone                 String                 @default("Australia/Sydney")
  participantNotes         String?
  adminNotes               String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
}

model AccessibilityProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobilityNeeds            Json     @default("[]")
  communicationPreferences Json     @default("[]")
  sensoryPreferences       Json     @default("{}")
  cognitivePreferences     Json     @default("{}")
  transportRequirements    Json     @default("{}")
  digitalPreferences       Json     @default("{}")
  shareWithProviders       Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Organisation {
  id                      String             @id @default(cuid())
  name                    String
  abn                     String?
  organisationType        OrganisationType
  contactEmail            String?
  contactPhone            String?
  website                 String?
  address                 String?
  serviceRegions          String[]           @default([])
  status                  OrganisationStatus @default(active)
  verificationStatus      VerificationStatus @default(not_started)
  ndisRegistrationClaimed Boolean            @default(false)
  ndisRegistrationNumber  String?
  insuranceStatus         String?
  notes                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  members     OrganisationMember[]
  consents    ConsentRecord[]
  bookings    Booking[]
  auditEvents AuditEvent[]
  invoices    Invoice[]

  careRequests           CareRequest[]
  careShifts             CareShift[]
  workerProfiles         WorkerProfile[]
  capacityBlocks         CapacityBlock[]
  vehicles               Vehicle[]
  driverProfiles         DriverProfile[]
  transportBookings      TransportBooking[] @relation("TransportOperator")
  employerJobs           Job[]              @relation("EmployerJobs")
  calendarEvents         CalendarEvent[]
  availabilityWindows    AvailabilityWindow[]

}

model OrganisationMember {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role           MapAbleUserRole @default(provider_admin)
  createdAt      DateTime        @default(now())

  @@unique([userId, organisationId])
}

model ConsentRecord {
  id                      String        @id @default(cuid())
  subjectUserId           String
  subjectUser             User          @relation("ConsentSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  grantedToUserId         String?
  grantedToUser           User?         @relation("ConsentGrantedToUser", fields: [grantedToUserId], references: [id], onDelete: SetNull)
  grantedToOrganisationId String?
  grantedToOrganisation   Organisation? @relation(fields: [grantedToOrganisationId], references: [id], onDelete: SetNull)
  scope                   ConsentScope
  purpose                 String
  status                  ConsentStatus @default(active)
  expiryDate              DateTime?
  createdById             String
  createdBy               User          @relation("ConsentCreatedBy", fields: [createdById], references: [id])
  revokedById             String?
  revokedBy               User?         @relation("ConsentRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)
  revokedAt               DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([subjectUserId, status])
  @@index([grantedToOrganisationId])
}

model NotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  channel   NotificationChannel
  enabled   Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([userId, category, channel])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt])
}

model AuditEvent {
  id             String          @id @default(cuid())
  actorUserId    String?
  actorUser      User?           @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole      MapAbleUserRole?
  action         String
  entityType     String
  entityId       String?
  participantId  String?
  organisationId String?
  organisation   Organisation?   @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())

  @@index([action])
  @@index([participantId])
  @@index([createdAt])
}

model Booking {
  id                     String        @id @default(cuid())
  participantId          String
  participant            User          @relation("BookingParticipant", fields: [participantId], references: [id])
  bookingType            BookingType
  status                 BookingStatus @default(draft)
  requestedStart         DateTime
  requestedEnd           DateTime?
  pickupAddress          String?
  dropoffAddress         String?
  careLocation           String?
  accessibilitySummary   String?
  participantNotes       String?
  providerNotes          String?
  assignedOrganisationId String?
  assignedOrganisation   Organisation? @relation(fields: [assignedOrganisationId], references: [id], onDelete: SetNull)
  assignedWorkerId       String?
  assignedWorker         User?         @relation("BookingAssignedWorker", fields: [assignedWorkerId], references: [id], onDelete: SetNull)
  assignedDriverId       String?
  assignedDriver         User?         @relation("BookingAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  fundingSourceTag       String?
  shareAccessibility     Boolean       @default(false)
  createdById            String
  createdBy              User          @relation("BookingCreatedBy", fields: [createdById], references: [id])
  providerResponseStatus ProviderResponseStatus @default(not_sent)
  providerResponseNote   String?
  providerRespondedAt    DateTime?
  fundingSourceId      String?
  fundingSource        ParticipantFundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  invoices             Invoice[]
  timelineEvents       BookingTimelineEvent[]
  conversations        Conversation[]
  documents            Document[]

  careRequest        CareRequest?
  careShifts         CareShift[]
  transportBooking   TransportBooking?

  segments               BookingSegment[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([participantId, status])
}

model BookingSegment {
  id                  String    @id @default(cuid())
  bookingId           String
  booking             Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  segmentType         String
  startTime           DateTime?
  endTime             DateTime?
  pickupAddress       String?
  dropoffAddress      String?
  bufferBeforeMinutes Int       @default(0)
  bufferAfterMinutes  Int       @default(0)
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
}

// --- MapAble Core Phase 2 ---

enum ConversationType {
  participant_provider
  participant_support_coordinator
  participant_admin
  booking_thread
  support_ticket_thread
  organisation_admin
}

enum SupportTicketCategory {
  booking_help
  transport_issue
  care_provider_issue
  accessibility_issue
  billing_question
  profile_help
  technical_issue
  complaint
  safeguarding_concern
  other
}

enum SupportTicketStatus {
  open
  triage
  waiting_on_user
  waiting_on_provider
  escalated
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum DocumentCategory {
  participant_identity
  participant_plan
  service_agreement
  provider_insurance
  provider_registration
  worker_screening
  booking_attachment
  invoice_attachment
  support_ticket_attachment
  accessibility_evidence
  other
}

enum DocumentVisibility {
  private_to_participant
  shared_with_provider
  shared_with_plan_manager
  admin_only
  organisation_private
}

enum DocumentScanStatus {
  not_configured
  pending
  passed
  failed
}

enum FundingSourceType {
  ndis_self_managed
  ndis_plan_managed
  ndis_agency_managed
  private_pay
  aged_care
  employer
  other
}

enum FundingSourceStatus {
  active
  inactive
  pending_review
  expired
}

enum InvoiceStatus {
  draft
  preflight_required
  preflight_failed
  approved_for_invoicing
  xero_sync_pending
  xero_synced
  stripe_payment_pending
  partially_paid
  paid
  voided
}

enum BillingPreflightStatus {
  passed
  failed
}

enum ProviderResponseStatus {
  not_sent
  sent
  accepted
  declined
  expired
}

enum BookingTimelineEventType {
  booking_created
  booking_submitted
  booking_assigned
  provider_accepted
  provider_declined
  booking_confirmed
  booking_completed
  invoice_drafted
  support_ticket_created
  message_sent
}

model Conversation {
  id              String           @id @default(cuid())
  type            ConversationType
  title           String
  participantId   String?
  bookingId       String?
  booking         Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  supportTicketId String?
  organisationId  String?
  createdById     String
  createdBy       User             @relation("ConversationCreatedBy", fields: [createdById], references: [id])
  lastMessageAt   DateTime?
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([participantId])
  @@index([bookingId])
  @@index([organisationId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id                 String       @id @default(cuid())
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId       String
  sender             User         @relation("MessageSender", fields: [senderUserId], references: [id])
  body               String
  plainLanguageSummary String?
  attachmentDocumentIds String[]   @default([])
  createdAt          DateTime     @default(now())
  editedAt           DateTime?
  deletedAt          DateTime?

  readReceipts MessageReadReceipt[]

  @@index([conversationId, createdAt])
}

model MessageReadReceipt {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
}

model SupportTicket {
  id                    String                @id @default(cuid())
  title                 String
  description           String
  category              SupportTicketCategory
  status                SupportTicketStatus   @default(open)
  priority              SupportTicketPriority @default(normal)
  participantId         String?
  organisationId        String?
  bookingId             String?
  assignedAdminId       String?
  assignedAdmin         User?                 @relation("TicketAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  createdById           String
  createdBy             User                  @relation("TicketCreatedBy", fields: [createdById], references: [id])
  escalationReason      String?
  resolutionSummary     String?
  requiresIncidentReview Boolean              @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  closedAt              DateTime?

  comments  SupportTicketComment[]
  documents Document[]

  @@index([status])
  @@index([participantId])
  @@index([organisationId])
  @@index([priority])
}

model SupportTicketComment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  body      String
  isInternal Boolean      @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

model Document {
  id              String             @id @default(cuid())
  title           String
  category        DocumentCategory
  visibility      DocumentVisibility @default(private_to_participant)
  fileKey         String
  mimeType        String
  fileSize        Int
  scanStatus      DocumentScanStatus @default(not_configured)
  uploadedById    String
  uploadedBy      User               @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  participantId   String?
  organisationId  String?
  bookingId       String?
  booking         Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  supportTicketId String?
  supportTicket   SupportTicket?     @relation(fields: [supportTicketId], references: [id], onDelete: SetNull)
  invoiceId       String?
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  description     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([participantId])
  @@index([organisationId])
  @@index([bookingId])
}

model ParticipantFundingSource {
  id                      String              @id @default(cuid())
  participantId           String
  participant             User                @relation("ParticipantFundingSources", fields: [participantId], references: [id], onDelete: Cascade)
  type                    FundingSourceType
  displayName             String
  status                  FundingSourceStatus @default(pending_review)
  planManagerOrganisationId String?
  planManagerContactName  String?
  planManagerEmail        String?
  planStartDate           DateTime?
  planEndDate             DateTime?
  notes                   String?
  createdById             String
  createdBy               User                @relation("FundingSourceCreatedBy", fields: [createdById], references: [id])
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  bookings Booking[]
  careRequests CareRequest[]
  invoices Invoice[]

  @@index([participantId, status])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String?
  participantId   String
  participant     User          @relation("InvoiceParticipant", fields: [participantId], references: [id])
  organisationId  String?
  organisation    Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  bookingId       String?
  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  fundingSourceId String?
  fundingSource   ParticipantFundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  status          InvoiceStatus @default(draft)
  issueDate       DateTime?
  dueDate         DateTime?
  subtotalCents   Int           @default(0)
  taxCents        Int           @default(0)
  totalCents      Int           @default(0)
  currency        String        @default("AUD")
  notes           String?
  createdById     String
  createdBy       User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lines            InvoiceLine[]
  documents        Document[]
  preflightResults BillingPreflightResult[]
  xeroSyncRecords  XeroInvoiceSyncRecord[]
  stripePayments   StripePaymentIntentRecord[]

  @@index([participantId, status])
  @@index([organisationId])
}

model InvoiceLine {
  id                   String   @id @default(cuid())
  invoiceId            String
  invoice              Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  bookingId            String?
  description          String
  serviceDate          DateTime
  quantity             Decimal  @default(1)
  unitAmountCents      Int
  totalAmountCents     Int
  supportItemCode      String?
  claimableByNdis      Boolean  @default(false)
  privatePayAmountCents Int?
  ndisClaimableAmountCents Int?
  taxCode              String?

  @@unique([invoiceId])
  @@index([invoiceId])
}

model BillingPreflightResult {
  id            String                 @id @default(cuid())
  invoiceId     String
  invoice       Invoice                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  status        BillingPreflightStatus
  checks        Json
  failedReasons Json?
  createdById   String
  createdBy     User                   @relation(fields: [createdById], references: [id])
  createdAt     DateTime               @default(now())

  @@index([invoiceId, createdAt])
}

model StripeCustomerLink {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId String
  createdAt        DateTime @default(now())
}

model StripePaymentIntentRecord {
  id                    String   @id @default(cuid())
  invoiceId             String
  invoice               Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String   @unique
  amountCents           Int
  currency              String   @default("AUD")
  status                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  processedAt   DateTime?
  payload       Json?
  createdAt     DateTime @default(now())
}

model XeroTenantConnection {
  id           String   @id @default(cuid())
  tenantId     String
  tenantName   String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model XeroContactLink {
  id             String   @id @default(cuid())
  organisationId String?  @unique
  participantId  String?  @unique
  xeroContactId  String
  createdAt      DateTime @default(now())
}

model XeroInvoiceSyncRecord {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  xeroInvoiceId String?
  syncStatus    String   @default("pending")
  lastError     String?
  syncedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([invoiceId])
}

model BookingTimelineEvent {
  id          String                 @id @default(cuid())
  bookingId   String
  booking     Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  eventType   BookingTimelineEventType
  title       String
  description String?
  actorUserId String?
  actor       User?                  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  isAdminOnly Boolean                @default(false)
  createdAt   DateTime               @default(now())

  @@index([bookingId, createdAt])
}

// --- MapAble Core Phase 3 ---

enum CareRequestType {
  personal_care
  domestic_assistance
  community_access
  appointment_support
  employment_support
  meal_preparation
  therapy_assistance
  skill_building
  overnight_support
  other
}

enum CareRequestStatus {
  draft
  submitted
  awaiting_admin_review
  awaiting_provider_response
  matched
  confirmed
  in_progress
  completed
  cancelled
  disputed
}

enum CareShiftStatus {
  scheduled
  worker_assigned
  confirmed
  worker_en_route
  checked_in
  in_progress
  checked_out
  awaiting_participant_approval
  approved
  completed
  cancelled
  disputed
}

enum WorkerCredentialStatus {
  not_provided
  pending_review
  verified
  expired
  rejected
}

enum TransportBookingType {
  one_way
  return_trip
  multi_stop_placeholder
}

enum TransportBookingStatus {
  draft
  requested
  awaiting_operator_response
  operator_accepted
  driver_assigned
  vehicle_assigned
  confirmed
  driver_en_route
  arrived_for_pickup
  participant_on_board
  in_transit
  arrived_at_destination
  completed
  cancelled
  disputed
}

enum VehicleType {
  standard_car
  wheelchair_accessible_taxi
  accessible_van
  community_transport_bus
  other
}

enum JobStatus {
  draft
  published
  closed
  archived
}

enum EmploymentType {
  full_time
  part_time
  casual
  contract
  volunteer
  work_experience
  supported_employment
}

enum JobApplicationStatus {
  draft
  submitted
  under_review
  interview_requested
  successful
  unsuccessful
  withdrawn
}

enum CalendarEventType {
  care_request
  care_shift
  transport_booking
  job_application
  job_interview
  support_ticket_followup
  admin_task
}

enum CalendarVisibility {
  participant_private
  organisation
  employer
  admin_only
}

enum OrchestrationEventType {
  care_transport_link_created
  interview_transport_draft_created
  invoice_from_care_shift
  care_request_submitted
}

model CareRequest {
  id                      String            @id @default(cuid())
  participantId           String
  participant             User              @relation("CareRequestParticipant", fields: [participantId], references: [id])
  requestType             CareRequestType
  title                   String
  description             String
  preferredDate           DateTime?
  startTime               String?
  endTime                 String?
  recurrencePlaceholder   Boolean           @default(false)
  locationType            String?
  address                 String?
  suburb                  String?
  state                   String?
  accessRequirementsSummary String?
  tasks                   Json              @default("[]")
  communicationNotes      String?
  preferredWorkerAttributes Json?
  genderPreference        String?
  supportItemCode         String?
  fundingSourceId         String?
  fundingSource           ParticipantFundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: SetNull)
  linkedTransportRequired Boolean           @default(false)
  shareAccessibility      Boolean           @default(false)
  status                  CareRequestStatus @default(draft)
  createdById             String
  createdBy               User              @relation("CareRequestCreatedBy", fields: [createdById], references: [id])
  assignedOrganisationId  String?
  assignedOrganisation    Organisation?     @relation(fields: [assignedOrganisationId], references: [id], onDelete: SetNull)
  assignedWorkerId        String?
  assignedWorkerProfileId String?
  assignedWorkerProfile   WorkerProfile?    @relation(fields: [assignedWorkerProfileId], references: [id], onDelete: SetNull)
  bookingId               String?           @unique
  booking                 Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  shifts                  CareShift[]
  calendarEvents          CalendarEvent[]
  orchestrationEvents     OrchestrationEvent[]

  @@index([participantId, status])
  @@index([assignedOrganisationId])
}

model CareShift {
  id                      String          @id @default(cuid())
  careRequestId           String
  careRequest             CareRequest     @relation(fields: [careRequestId], references: [id], onDelete: Cascade)
  bookingId               String?           @unique
  booking                 Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participantId           String
  participant             User              @relation("CareShiftParticipant", fields: [participantId], references: [id])
  organisationId          String
  organisation            Organisation    @relation(fields: [organisationId], references: [id])
  workerProfileId         String?
  workerProfile           WorkerProfile?  @relation(fields: [workerProfileId], references: [id], onDelete: SetNull)
  startAt                 DateTime
  endAt                   DateTime
  location                String?
  tasks                   Json              @default("[]")
  accessRequirementsSnapshot Json?
  status                  CareShiftStatus   @default(scheduled)
  checkInTime             DateTime?
  checkOutTime            DateTime?
  checkInLatPlaceholder   Float?
  checkInLngPlaceholder   Float?
  workerNotes             String?
  participantApprovalStatus String        @default("pending")
  approvedById            String?
  approvedBy              User?           @relation("CareShiftApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt              DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  calendarEvents          CalendarEvent[]

  @@index([participantId, status])
  @@index([organisationId])
  @@index([workerProfileId])
}

model WorkerProfile {
  id                      String                 @id @default(cuid())
  userId                  String?
  user                    User?                  @relation("WorkerProfileUser", fields: [userId], references: [id], onDelete: SetNull)
  organisationId          String
  organisation            Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  displayName             String
  profileSummary          String?
  serviceTypes            String[]               @default([])
  serviceRegions          String[]               @default([])
  languages               String[]               @default([])
  communicationCapabilities Json                 @default("[]")
  qualificationsSummary   String?
  workerScreeningStatus   WorkerCredentialStatus @default(not_provided)
  wwccStatus              WorkerCredentialStatus @default(not_provided)
  firstAidStatus          WorkerCredentialStatus @default(not_provided)
  insuranceStatus         WorkerCredentialStatus @default(not_provided)
  verificationStatus      WorkerCredentialStatus @default(pending_review)
  active                  Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  careRequests            CareRequest[]
  careShifts              CareShift[]
  availabilityWindows     AvailabilityWindow[]

  @@index([organisationId, active])
}

model AvailabilityWindow {
  id             String          @id @default(cuid())
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  workerProfileId String?
  workerProfile  WorkerProfile?  @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  driverProfileId String?
  driverProfile  DriverProfile?  @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  vehicleId      String?
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
  timezone       String          @default("Australia/Sydney")
  effectiveFrom  DateTime        @default(now())
  effectiveTo    DateTime?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())

  @@index([organisationId])
}

model CapacityBlock {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  date           DateTime
  serviceType    String
  totalCapacity  Int          @default(0)
  bookedCapacity Int          @default(0)
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([organisationId, date])
}

model TransportBooking {
  id                    String                 @id @default(cuid())
  bookingId             String?                @unique
  booking               Booking?               @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participantId         String
  participant           User                   @relation("TransportBookingParticipant", fields: [participantId], references: [id])
  transportType         TransportBookingType   @default(one_way)
  pickupAddress         String
  pickupLat             Float?
  pickupLng             Float?
  pickupWindowStart     DateTime
  pickupWindowEnd       DateTime?
  dropoffAddress        String
  dropoffLat            Float?
  dropoffLng            Float?
  appointmentTime       DateTime?
  returnTripRequired    Boolean                @default(false)
  returnPickupTime      DateTime?
  passengerCount        Int                    @default(1)
  mobilityAidSnapshot   Json?
  vehicleRequirements   Json                   @default("{}")
  driverAssistanceRequired Boolean             @default(false)
  pickupNotes           String?
  dropoffNotes          String?
  shareAccessibility    Boolean                @default(false)
  status                TransportBookingStatus @default(draft)
  operatorOrganisationId String?
  operatorOrganisation  Organisation?          @relation("TransportOperator", fields: [operatorOrganisationId], references: [id], onDelete: SetNull)
  driverProfileId       String?
  driverProfile         DriverProfile?         @relation(fields: [driverProfileId], references: [id], onDelete: SetNull)
  vehicleId             String?
  vehicle               Vehicle?               @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  careRequestId         String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  calendarEvents        CalendarEvent[]

  @@index([participantId, status])
  @@index([operatorOrganisationId])
}

model Vehicle {
  id                   String                 @id @default(cuid())
  organisationId       String
  organisation         Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  displayName          String
  vehicleType          VehicleType            @default(standard_car)
  registrationNumber   String?
  wheelchairAccessible Boolean                @default(false)
  rampAvailable        Boolean                @default(false)
  liftAvailable        Boolean                @default(false)
  wheelchairSpaces     Int                    @default(0)
  seatedCapacity       Int                    @default(4)
  canCarryPowerWheelchair Boolean             @default(false)
  assistanceAnimalFriendly Boolean           @default(true)
  airConditioning      Boolean                @default(true)
  notes                String?
  verificationStatus   WorkerCredentialStatus @default(pending_review)
  active               Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  transportBookings    TransportBooking[]
  availabilityWindows  AvailabilityWindow[]

  @@index([organisationId])
}

model DriverProfile {
  id                      String                 @id @default(cuid())
  userId                  String?
  user                    User?                  @relation("DriverProfileUser", fields: [userId], references: [id], onDelete: SetNull)
  organisationId          String
  organisation            Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  displayName             String
  phone                   String?
  serviceRegions          String[]               @default([])
  licenceStatus           WorkerCredentialStatus @default(not_provided)
  accessibilityTrainingStatus WorkerCredentialStatus @default(not_provided)
  workerScreeningStatus   WorkerCredentialStatus @default(not_provided)
  active                  Boolean                @default(true)
  verificationStatus      WorkerCredentialStatus @default(pending_review)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  transportBookings       TransportBooking[]
  availabilityWindows     AvailabilityWindow[]

  @@index([organisationId])
}

model Job {
  id                        String       @id @default(cuid())
  employerOrganisationId    String
  employerOrganisation      Organisation @relation("EmployerJobs", fields: [employerOrganisationId], references: [id])
  title                     String
  description               String
  employmentType            EmploymentType
  location                  String?
  remoteAllowed             Boolean      @default(false)
  flexibleHours             Boolean      @default(false)
  payRange                  String?
  accessibilityFeatures     Json         @default("{}")
  adjustmentOpennessStatement String?
  applicationInstructions   String?
  status                    JobStatus    @default(draft)
  createdById               String
  createdBy                 User         @relation("JobCreatedBy", fields: [createdById], references: [id])
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  applications              JobApplication[]
  calendarEvents            CalendarEvent[]

  @@index([status])
  @@index([employerOrganisationId])
}

model JobApplication {
  id                        String               @id @default(cuid())
  jobId                     String
  job                       Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  participantId             String
  participant               User                 @relation("JobApplicationParticipant", fields: [participantId], references: [id])
  applicantSummary          String?
  resumeDocumentId          String?
  coverLetter               String?
  reasonableAdjustmentRequest String?
  shareAdjustments          Boolean              @default(false)
  transportSupportNeeded    Boolean              @default(false)
  careSupportNeeded         Boolean              @default(false)
  status                    JobApplicationStatus @default(draft)
  submittedAt               DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  calendarEvents            CalendarEvent[]

  @@index([jobId])
  @@index([participantId, status])
}

model CalendarEvent {
  id                  String             @id @default(cuid())
  eventType           CalendarEventType
  title               String
  description         String?
  startAt             DateTime
  endAt               DateTime
  timezone            String             @default("Australia/Sydney")
  participantId       String?
  participant         User?              @relation("CalendarEventParticipant", fields: [participantId], references: [id], onDelete: Cascade)
  organisationId      String?
  organisation        Organisation?      @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  bookingId           String?
  careRequestId       String?
  careRequest         CareRequest?       @relation(fields: [careRequestId], references: [id], onDelete: SetNull)
  careShiftId         String?
  careShift           CareShift?         @relation(fields: [careShiftId], references: [id], onDelete: SetNull)
  transportBookingId  String?
  transportBooking    TransportBooking?  @relation(fields: [transportBookingId], references: [id], onDelete: SetNull)
  jobApplicationId    String?
  jobApplication      JobApplication?    @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  jobId               String?
  job                 Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  visibility          CalendarVisibility @default(participant_private)
  externalSyncPlaceholder Boolean          @default(false)
  createdById         String
  createdBy           User               @relation("CalendarEventCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([participantId, startAt])
  @@index([organisationId, startAt])
}

model OrchestrationEvent {
  id              String                 @id @default(cuid())
  eventType       OrchestrationEventType
  careRequestId   String?
  careRequest     CareRequest?           @relation(fields: [careRequestId], references: [id], onDelete: SetNull)
  transportBookingId String?
  bookingId       String?
  jobApplicationId String?
  careShiftId     String?
  metadata        Json?
  idempotencyKey  String?                @unique
  createdById     String?
  createdAt       DateTime               @default(now())

  @@index([careRequestId])
}
