  submittedAt      DateTime?
  approvedAt       DateTime?
  rejectedReason   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([participantId, status])
  @@index([organisationId])
  @@index([workerProfileId])
}

model IncidentReport {
  id                      String           @id @default(cuid())
  category                IncidentCategory
  severity                IncidentSeverity @default(medium)
  status                  IncidentStatus   @default(draft)
  title                   String
  description             String
  participantId           String?
  bookingId               String?
  careShiftId             String?
  transportBookingId      String?
  organisationId          String?
  organisation            Organisation?    @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  workerProfileId         String?
  driverProfileId         String?
  vehicleId               String?
  reportedById            String
  reportedBy              User             @relation("IncidentReportedBy", fields: [reportedById], references: [id])
  adminOwner              User?            @relation("IncidentAdminOwner", fields: [adminOwnerId], references: [id], onDelete: SetNull)
  occurredAt              DateTime?
  immediateRiskPresent    Boolean          @default(false)
  possibleReportableIncident Boolean       @default(false)
  safeguardingConcern     Boolean          @default(false)
  adminOwnerId            String?
  adminAcknowledgedAt     DateTime?
  resolutionSummary       String?
  externalReportRef       String?
  escalatedToQscAt        DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  closedAt                DateTime?

