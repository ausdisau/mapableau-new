// MapAble Core Phase 9 — Mature civic platform

enum DataVaultRequestType {
  export
  portability
  deletion_review
}

enum DataVaultRequestStatus {
  pending
  processing
  completed
  rejected
}

model NationalRolloutStage {
  id              String   @id @default(cuid())
  regionCode      String   @unique
  name            String
  status          String   @default("planned")
  percentComplete Int      @default(0)
  notes           String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PartnerBillingAccount {
  id             String   @id @default(cuid())
  organisationId String   @unique
  planCode       String   @default("standard")
  status         String   @default("active")
  billingEmail   String?
  createdAt      DateTime @default(now())

  invoices PartnerBillingInvoice[]
}

model PartnerBillingInvoice {
  id          String   @id @default(cuid())
  accountId   String
  account     PartnerBillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodLabel String
  amountCents Int      @default(0)
  status      String   @default("draft")
  dueAt       DateTime?
  createdAt   DateTime @default(now())
}

model PartnerApiProgramEnrollment {
  id             String   @id @default(cuid())
  organisationId String
  programTier    String   @default("standard")
  status         String   @default("pending")
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
}

model AssessorNetworkMember {
  id         String   @id @default(cuid())
  userId     String   @unique
  credential String?
  regions    String[] @default([])
  status     String   @default("active")
  joinedAt   DateTime @default(now())
}

model PublicDecisionRecord {
  id           String   @id @default(cuid())
  title        String
  summary      String
  decisionType String
  rationale    String?
  status       String   @default("published")
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
}

model PersonalDataVaultRequest {
  id          String               @id @default(cuid())
  userId      String
  requestType DataVaultRequestType
  status      DataVaultRequestStatus @default(pending)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime             @default(now())
}

model ResearchSafeRoomProject {
  id                 String   @id @default(cuid())
  title              String
  status             String   @default("draft")
  ethicsApprovalId   String?
  accessPolicy       String   @default("restricted")
  syntheticDataOnly  Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model ProviderBenchmarkSnapshot {
  id             String   @id @default(cuid())
  organisationId String?
  metricKey      String
  value          Float?
  cohortSize     Int      @default(0)
  suppressed     Boolean  @default(false)
  periodLabel    String
  createdAt      DateTime @default(now())
}

model GovernanceCharter {
  id         String   @id @default(cuid())
  version    String   @unique
  title      String
  body       String
  status     String   @default("draft")
  ratifiedAt DateTime?
  createdAt  DateTime @default(now())
}

model LocaleTranslation {
  id        String   @id @default(cuid())
  locale    String
  namespace String   @default("common")
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key])
}

model LongitudinalImpactWave {
  id          String   @id @default(cuid())
  waveLabel   String
  status      String   @default("collecting")
  metricsJson Json?
  suppressed  Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}
