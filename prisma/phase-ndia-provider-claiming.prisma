// Registered provider NDIA claiming (PACE / NDIA partner API adapter)

enum NdiaProviderClaimStatus {
  draft
  validated
  dry_run_passed
  submitted
  accepted
  rejected
  paid
  failed
}

model NdiaProviderClaim {
  id                     String                  @id @default(cuid())
  organisationId         String
  organisation           Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  legacyInvoiceId        String?
  billingInvoiceId       String?
  participantId          String
  createdById            String
  ndisRegistrationNumber String
  status                 NdiaProviderClaimStatus @default(draft)
  claimPayloadJson       Json
  validationFindingsJson Json?
  externalClaimId        String?
  externalStatus         String?
  submittedAt            DateTime?
  paidAt                 DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  audits NdiaProviderClaimAudit[]

  @@index([organisationId, status])
  @@index([legacyInvoiceId])
  @@index([billingInvoiceId])
  @@index([externalClaimId])
}

model NdiaProviderClaimAudit {
  id        String          @id @default(cuid())
  claimId   String
  claim     NdiaProviderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  action    String
  actorId   String?
  before    Json?
  after     Json?
  createdAt DateTime        @default(now())

  @@index([claimId, createdAt])
}
