# Copy to android/keystore.properties (never commit the real file or keystore).
# Generate keystore locally:
#   keytool -genkey -v -keystore mapable-release.keystore -alias mapable \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Get SHA-256 for assetlinks.json:
#   keytool -list -v -keystore mapable-release.keystore -alias mapable

storeFile=../mapable-release.keystore
storePassword=CHANGE_ME
keyAlias=mapable
keyPassword=CHANGE_ME
