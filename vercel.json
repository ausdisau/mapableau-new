{
  "crons": [
    {
      "path": "/api/admin/ingest/ndis-providers",
      "schedule": "15 17 * * *"
    },
    {
      "path": "/api/cron/mapable-agent/embed",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "app/api/mapable-agent/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/mapable-agent/embed/route.ts": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.mapable.com.au" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/api/(.*)",
      "has": [{ "type": "host", "value": "peer.mapable.com.au" }],
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://peer.mapable.com.au" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
