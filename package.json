{
  "name": "mapable-workspace",
  "version": "1.0.1",
  "private": true,
  "description": "MapAble monorepo workspace",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter @mapable/web dev",
    "dev:debug": "pnpm --filter @mapable/web dev:debug",
    "build": "pnpm --filter @mapable/web build",
    "start": "pnpm --filter @mapable/web start",
    "lint": "pnpm --filter @mapable/web lint",
    "lint:fix": "pnpm --filter @mapable/web lint:fix",
    "type-check": "pnpm --filter @mapable/web type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install && prisma generate",
    "lint-staged": "lint-staged",
    "prepush": "pnpm type-check && pnpm format:check && pnpm lint && pnpm lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp:av": "tsx mcp/av/server.ts",
    "neon:configure": "python3 scripts/configure-neon-env.py",
    "check:integrations-env": "npx tsx scripts/check-integrations-env.ts"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.19.2",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "next": "15.5.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "prisma": "6.19.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
