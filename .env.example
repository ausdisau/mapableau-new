# PostgreSQL — local default; for Neon see docs/operations/neon.md
DATABASE_URL="postgresql://user:password@localhost:5432/mapable"
# Same as DATABASE_URL for local dev; for Neon use the *non-pooler* endpoint
DIRECT_URL="postgresql://user:password@localhost:5432/mapable"

# Neon example (from console.neon.tech → Connect):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Twilio Verify 2FA (optional — applies to email/password login when enabled)
TWILIO_2FA_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# OAuth sign-in (optional — buttons appear only when required provider vars are set)
# Auth0 → Application → redirect: {NEXTAUTH_URL}/api/auth/callback/auth0
# Configure Google/Facebook as Auth0 social connections in the Auth0 dashboard.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER_BASE_URL=
# Google Cloud Console → OAuth client → redirect: {NEXTAUTH_URL}/api/auth/callback/google
# Use GOOGLE_CLIENT_ID, GOOGLE_ID, or AUTH_GOOGLE_ID (same value);
# secret: GOOGLE_CLIENT_SECRET, GOOGLE_SECRET, or AUTH_GOOGLE_SECRET
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Meta for Developers → Facebook Login → redirect: {NEXTAUTH_URL}/api/auth/callback/facebook
# Use FACEBOOK_CLIENT_ID or FACEBOOK_APP_ID (same value); secret: FACEBOOK_CLIENT_SECRET or FACEBOOK_APP_SECRET
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Microsoft Entra / Azure AD → App registration → redirect: {NEXTAUTH_URL}/api/auth/callback/azure-ad
# AZURE_AD_TENANT_ID: "common" (default) for work + personal Microsoft accounts; or your tenant GUID
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
# Password reset emails (optional in local dev — reset link is logged to the server console)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@example.com"
NDIS_ENCRYPTION_KEY="change-me-in-production"

# Search autocomplete (Postgres):
# npx prisma db execute --schema prisma/schema.prisma --file prisma/sql/ensure-search-autocomplete.sql
# npx tsx prisma/seed-search-autocomplete.ts

# Storage
DOCUMENT_STORAGE_MODE=local
DOCUMENT_MAX_UPLOAD_MB=10

# Stripe (Node SDK — lib/stripe/)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=AUD
# Legacy Invoice routes also need one of:
BILLING_ENABLE_STRIPE=false
STRIPE_ENABLED=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
# MapAble PEERS peer subdomain (comma-separated). Middleware rewrites / → /peers internally.
# MAPABLE_PEER_PEERS_HOSTS=peer.mapable.com.au
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PROVIDER_PRO_PRICE_ID=
STRIPE_EMPLOYER_PRO_PRICE_ID=

# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
XERO_WEBHOOK_KEY=
XERO_DEFAULT_TENANT_ID=

# Billing
BILLING_DEFAULT_CURRENCY=AUD
BILLING_REQUIRE_PREFLIGHT=true
BILLING_ENABLE_STRIPE=false
BILLING_ENABLE_XERO=false

# Calendar
CALENDAR_EXTERNAL_SYNC_ENABLED=false

# MapAble AV MCP (Cursor — see docs/av-mcp.md)
# MAPABLE_BASE_URL=http://localhost:3000

# Transport
TRANSPORT_LIVE_TRACKING_ENABLED=false
TRANSPORT_ROUTING_ENABLED=true
TRANSPORT_ROUTING_PROVIDER=mock
OSRM_BASE_URL=http://router.project-osrm.org
GRAPHHOPPER_API_KEY=
OPENROUTESERVICE_API_KEY=

# TfNSW Open Data (Live Traffic NSW + Trip Planner) — server-side only; see docs/tfnsw-traffic.md
TFNSW_API_KEY=
# TRANSPORT_NSW_API_KEY=  # alias for TFNSW_API_KEY
TFNSW_LIVE_TRAFFIC_ENABLED=true
TFNSW_TRIP_PLANNER_ENABLED=true
TFNSW_ENRICH_ROUTE_ESTIMATES=false
TFNSW_CACHE_TTL_SECONDS=120

# Accessible ride-sharing (see docs/accessible-ride-share.md)
TRANSPORT_BOOKING_BRIDGE_ENABLED=false
TRANSPORT_RIDE_POOLING_ENABLED=false

# Jobs
JOBS_PUBLIC_BOARD_ENABLED=true

# Orchestration
ORCHESTRATION_ENABLED=true

# Tracking
TRANSPORT_LIVE_LOCATION_ENABLED=false
TRANSPORT_MANUAL_TRACKING_ENABLED=true

# Matching
MATCHING_ENGINE_ENABLED=true
MATCHING_ALLOW_ADMIN_OVERRIDE=true

# NDIS line item helper
NDIS_SUPPORT_ITEM_IMPORT_ENABLED=true
NDIS_AUTO_CLAIMING_ENABLED=false

# Contracts
SMART_CONTRACT_RUNNER_ENABLED=true
CONTRACTS_REQUIRE_ADMIN_FOR_CHANGES=true

# Incidents
INCIDENT_REPORTING_ENABLED=true
INCIDENT_EXTERNAL_REPORTING_ENABLED=false

# Analytics
ADMIN_ANALYTICS_ENABLED=true

# Phase 5 — AI matching
AI_MATCHING_ENABLED=false
AI_MATCHING_PROVIDER=disabled
AI_MATCHING_REQUIRE_HUMAN_REVIEW=true
FAIRNESS_CHECKS_ENABLED=true

# Provider verification
PROVIDER_VERIFICATION_ADVANCED_ENABLED=true

# NDIS pricing
NDIS_PRICING_IMPORT_ENABLED=true
NDIS_CLAIM_SUBMISSION_ENABLED=false
# Registered provider NDIA API claiming (see docs/ndia-provider-claiming.md)
NDIA_PROVIDER_ADAPTER_MODE=mock
NDIA_PROVIDER_API_BASE_URL=
NDIA_PROVIDER_TOKEN_URL=
NDIA_PROVIDER_API_CLIENT_ID=
NDIA_PROVIDER_API_CLIENT_SECRET=
NDIA_PROVIDER_CLAIM_SUBMIT_PATH=/v1/provider/claims
NDIA_PROVIDER_REQUIRE_HUMAN_APPROVAL=true

# Xero (Phase 5 direct integration)
XERO_ENABLED=false

# Stripe (Phase 5 billing maturity)
STRIPE_ENABLED=false

# Mobile contracts
MOBILE_CONTRACTS_ENABLED=true

# Route optimisation
ROUTE_OPTIMISATION_ENABLED=false
ROUTE_PROVIDER=disabled

# Developer API
DEVELOPER_API_ENABLED=false
API_RATE_LIMITING_ENABLED=true

# Reporting
REPORTING_ENABLED=true
SMALL_CELL_SUPPRESSION_THRESHOLD=5

# Compliance & security readiness
COMPLIANCE_EVIDENCE_ENABLED=true
SECURITY_READINESS_ENABLED=true
NDIA_READINESS_ENABLED=true
NDIA_REAL_SUBMISSION_ENABLED=false

# Phase 6 — Production & ecosystem launch
MOBILE_PRODUCTION_READINESS_ENABLED=true
DISPATCH_CONSOLE_ENABLED=true
PROVIDER_QUALITY_DASHBOARD_ENABLED=true
AI_GOVERNANCE_ENABLED=true
PARTNER_SANDBOX_ENABLED=true
OPEN_DATA_EXPORT_ENABLED=false
GOVERNMENT_REPORTING_ENABLED=false
DISASTER_RECOVERY_EXERCISES_ENABLED=true
COMMUNITY_GOVERNANCE_ENABLED=true

# Phase 7 — Live pilot & scale
MULTI_TENANT_PARTNER_ADMIN_ENABLED=true
PUBLIC_BETA_ENABLED=false
ENTERPRISE_PROVIDER_CONSOLE_ENABLED=true
GOVERNMENT_PARTNER_PORTAL_ENABLED=false
SOCIAL_IMPACT_MEASUREMENT_ENABLED=true
NDIA_PILOT_ENABLED=false

# Phase 8 — National infrastructure
APP_STORE_RELEASE_PROCESS_ENABLED=true
NATIONAL_INSIGHTS_ENABLED=true
PARTNER_MARKETPLACE_ENABLED=false
PUBLIC_API_VERSIONING_ENABLED=true
SLA_REPORTING_ENABLED=true
EXTERNAL_SECURITY_AUDIT_READINESS_ENABLED=true
DATA_TRUST_COUNCIL_ENABLED=true

# Phase 9 — Mature civic platform
PUBLIC_API_PARTNER_PROGRAM_ENABLED=false
PERSONAL_DATA_VAULT_ENABLED=true
RESEARCH_SAFE_ROOM_ENABLED=false
PUBLIC_DECISION_REGISTER_ENABLED=true
INTERNATIONALISATION_ENABLED=true
LONGITUDINAL_IMPACT_ENABLED=true

# Phase 10 — Public-interest OS
API_CERTIFICATION_PROGRAM_ENABLED=false
PRIVACY_PRESERVING_ANALYTICS_ENABLED=true
FEDERATED_RESEARCH_ENABLED=false
PUBLIC_ALGORITHM_REGISTER_ENABLED=true
OVERSIGHT_BOARD_PORTAL_ENABLED=true
SUSTAINABILITY_PLAN_ENABLED=true

# Y1 wedge — Cursor masterplan trust infrastructure (all default false)
SUPPORT_PROFILE_ENABLED=false
PARTICIPANT_MATCH_REVIEW_ENABLED=false
INCIDENT_INTAKE_V2_ENABLED=false
MICRO_CONSENT_ENABLED=false
BACKUP_SHIFT_RECOVERY_ENABLED=false

# Y2 orchestration — Cursor masterplan pilot scale (all default false)
BACKUP_RECOVERY_PILOT_ENABLED=false
CARE_TRANSPORT_ORCHESTRATION_V2_ENABLED=false
MICRO_CONSENT_V2_ENABLED=false
PLAN_MANAGER_INTEGRATION_ENABLED=false
SUPPORT_COORDINATOR_PORTAL_ENABLED=false
PAYMENT_RECONCILIATION_V2_ENABLED=false
MULTI_TENANT_WORKSPACE_V2_ENABLED=false
CARE_TRANSPORT_PICKUP_BUFFER_MINUTES=30
RECONCILIATION_AMOUNT_TOLERANCE_CENTS=1

# Phase 12 — Federated institutional accountability (includes deferred Phase 11 preview)
NATIONAL_ACCOUNTABILITY_PORTAL_ENABLED=true
CONSTITUTIONAL_SAFEGUARDS_ENABLED=true
COMMUNITY_GOVERNANCE_MEMBERSHIP_ENABLED=true
TRANSPORT_INVESTMENT_MODELLING_ENABLED=true
CERTIFIED_API_ECOSYSTEM_AT_SCALE_ENABLED=false
RESEARCH_FEDERATION_AT_SCALE_ENABLED=false
INSTITUTIONAL_CONTINUITY_ENABLED=true
CIVIC_AUDIT_INDEX_ENABLED=true
FEDERATED_ACCOUNTABILITY_ENABLED=true

# --- Open-source integration pack ---
MAP_INTEGRATION_ENABLED=true
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors
NEXT_PUBLIC_MAP_DEFAULT_LAT=-33.8688
NEXT_PUBLIC_MAP_DEFAULT_LNG=151.2093
